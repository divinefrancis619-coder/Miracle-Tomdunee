!function(){try{var e="u">typeof window?window:"u">typeof global?global:"u">typeof globalThis?globalThis:"u">typeof self?self:{},t=(new e.Error).stack;t&&(e._sentryDebugIds=e._sentryDebugIds||{},e._sentryDebugIds[t]="0766d456-7703-48b8-b712-54f68c5e5f5c",e._sentryDebugIdIdentifier="sentry-dbid-0766d456-7703-48b8-b712-54f68c5e5f5c")}catch(e){}}();"use strict";(self.webpackChunk_N_E=self.webpackChunk_N_E||[]).push([[72137],{3947:(e,t,o)=>{o.r(t),o.d(t,{default:()=>a});let a={src:"/_next/static/media/sunny-academy-no-background.c21a8f9e.png",height:499,width:500,blurDataURL:"data:image/png;base64,",blurWidth:8,blurHeight:8}},5666:(e,t,o)=>{o.r(t),o.d(t,{default:()=>a});let a={src:"/_next/static/media/sam-academy.efdb6294.png",height:270,width:270,blurDataURL:"data:image/png;base64,",blurWidth:8,blurHeight:8}},10798:(e,t,o)=>{o.r(t),o.d(t,{default:()=>a});let a={src:"/_next/static/media/kevin-olympus-academy.005d179a.png",height:365,width:365,blurDataURL:"data:image/png;base64,",blurWidth:8,blurHeight:8}},10803:(e,t,o)=>{o.r(t),o.d(t,{default:()=>a});let a={src:"/_next/static/media/david-olympus-academy.12101d61.png",height:365,width:365,blurDataURL:"data:image/png;base64,",blurWidth:8,blurHeight:8}},11084:(e,t,o)=>{o.r(t),o.d(t,{default:()=>a});let a={src:"/_next/static/media/jamal-academy.17fc79d8.png",height:365,width:365,blurDataURL:"data:image/png;base64,",blurWidth:8,blurHeight:8}},22718:(e,t,o)=>{o.r(t),o.d(t,{default:()=>a});let a={src:"/_next/static/media/michael-olympus-academy.befd5f33.png",height:365,width:365,blurDataURL:"data:image/png;base64,",blurWidth:8,blurHeight:8}},22770:(e,t,o)=>{o.r(t),o.d(t,{default:()=>a});let a={src:"/_next/static/media/james-academy-no-background.3c513d65.png",height:491,width:508,blurDataURL:"data:image/png;base64,",blurWidth:8,blurHeight:8}},29510:(e,t,o)=>{o.d(t,{A:()=>h});var a=o(95155),n=o(69730),i=o.n(n),s=o(622),r=o(55679);let l={black:"before:bg-black",purple:"before:bg-[#9F40FE]"},h=({items:e,title:t,className:o,color: