0%] md:leading-[100%]",captionMedium:"text-xs md:text-sm leading-[120%] md:leading-[100%]",captionMonoLarge:"text-sm md:text-base tracking-[0.42px] md:tracking-[0.48px] uppercase font-soehneMono",captionMonoMedium:"text-xs tracking-[0.6px] uppercase font-soehneMono",captionMonoSmall:"text-[10px] tracking-[0.5px] uppercase font-soehneMono",buttonLarge:"text-base md:text-lg xl:text-xl leading-[130%] tracking-[0.48px] md:tracking-[0.54px] xl:tracking-[0.6px] uppercase font-soehneMono",buttonSmall:"text-sm leading-[100%] tracking-[0.42px] uppercase font-soehneMono"},c={h1:`${s().variable}`,h2:`${s().variable}`,h3:`${s().variable}`,h4:`${s().variable}`,h5:`${s().variable}`,h6:`${s().variable}`,bodyLarge:`${s().variable}`,bodySmall:`${s().variable}`,sidebarLarge:`${s().variable}`,sidebarSmall:`${s().variable}`,caption:`${s().variable}`,captionMedium:`${s().variable}`,bodyMedium:`${s().variable}`,captionMonoLarge:`${l().variable}`,captionMonoMedium:`${l().variable}`,captionMonoSmall:`${l().variable}`,buttonLarge:`${l().variable}`,buttonSmall:`${l().variable}`},g=({variant:e="bodyLarge",className:t,component:o,children:i,...s})=>{let r=u[o||e]||h,l=c[e]||"";return(0,a.jsx)(r,{className:(0,n.QP)(d[e],t,l),...s,children:i})}},57949:(e,t,o)=>{o.d(t,{I1:()=>s,LD:()=>i,Vk:()=>r,f$:()=>u,gK:()=>n,gU:()=>h,jJ:()=>c,qT:()=>l,xO:()=>d});var a=o(95155);let n={masterClass:"Master Class",learn:"Learn Apollo",webinar:"Webinar",olympus:"Olympus"},i={outbound:"Outbound",inbound:"Inbound",dataEnrichment:"Data Enrichment",dealExecution:"Deal Execution"},s={workflowsAndAutomations:"workflowsAndAutomations",sequences:"sequences",conversations:"conversations",scorecards:"scorecards",powerUps:"powerUps",preMeetingInsights:"preMeetingInsights"},r={workflowsAndAutomations:"Ready to put this workflow into action?",sequences:"Ready to put this sequence into action?",conversations:"Ready to put this template into action?",scorecards:"Ready to put this template into action?",powerUps:(0,a.jsx)(a.Fragment,{children:"Ready to put this Research Prompt into action?"}),preMeetingInsights:"Ready to put this Insight into action?"},l={search:"Contact & Account Search",dataEnrichment:"Enrichment",engagement:"Engagement",meetings:"Meetings",conversations:"Conversations",deals:"Deals",workflowsAndAutomations:"Workflows & Automations",analytics:"Analytics",crmAndIntegrations:"CRM & Integrations",aiResearch:"AI Research Prompts"},h={[n.masterClass]:"/academy/master-classes",[n.learn]:"/academy/learn",[n.webinar]:"/academy/webinars",[n.olympus]:"/academy/webinars",[i.outbound]:"/academy/outbound",[i.dealExecution]:"/academy/deal-execution",[i.inbound]:"/academy/inbound",[i.dataEnrichment]:"/academy/data-enrichment",[l.search]:"/academy/contact-and-account-search",[l.dataEnrichment]:"/academy/enrichment",[l.engagement]:"/academy/engagement",[l.meetings]:"/academy/meetings",[l.conversations]:"/academy/conversations",[l.deals]:"/academy/deals",[l.workflowsAndAutomations]:"/academy/workflows-and-automations",[l.analytics]:"/academy/analytics",[l.crmAndIntegrations]:"/academy/crm-and-integrations",[l.aiResearch]:"/academy/ai-research"},u="/academy/templates",d={[s.workflowsAndAutomations]:"https://app.apollo.io/#/workflows",[s.conversations]:"https://app.apollo.io/#/conversations",[s.scorecards]:"https://app.apollo.io/#/settings/conversations/scorecards",[s.sequences]:"https://app.apollo.io/#/sequences",[s.powerUps]:"https://app.apollo.io/#/people",[s.preMeetingInsights]:"https://app.apollo.io/#/meetings/scheduled-meetings"},c={[s.workflowsAndAutomations]:"templateId",[s.conversations]:"template",[s.scorecards]:"template",[s.sequences]:"template",[s.powerUps]:"prospectedByCurrentTeam[]=yes&selectedPowerupTemplate",[s.preMeetingInsights]:"meetingStage=upcoming&sortByField=start_time&sortAscending=true&dateRange[min]=2025-01-13&selected_powerup_template_id"}},58666:(e,t,o)=>{o.r(t),o.d(t,{default:()=>a});let a={src:"/_next/static/media/chantel-olympus-academy.2a499239.png",height:365,width:365,blurDataURL:"data:image/png;base64,",blurWidth:8,blurHeight:8}},63226:(e,t,o)=>{o.d(t,{Cu:()=>b,J:()=>j,LN:()=>v,M1:()=>c,Q3:()=>m,S6:()=>u,T8:()=>A,V$:()=>d,V1:()=>f,Y8:()=>g,ZU:()=>w,__:()=>x,ab:()=>I,cY:()=>y,ic:()=>p,xy:()=>k});var a=o(95155),n=o(7612),i=o(29510),s=o(55679),r=o(45697),l=o(60252);let h=({href:e,children:t})=>(0,a.jsx)(r.default,{href:e,target:"_blank",underline:!0,component:"span",color:"#9F40FE",underlineColor:"#9F40FE",children:t}),u=[{title:"The three principles of social selling",wistiaId:"5czbukdzsd",length:"5:24",deepLink:{color:"purple",heading:"Convert LinkedIn prospects into pipeline with Apollo",linkText:"Try Apollo for free",url:"/sign-up"},description:(0,a.jsxs)("div",{className:"flex flex-col gap-6",children:[(0,a.jsx)(s.A,{variant:"h5",children:"People buy from people they trust."}),(0,a.jsx)(s.A,{children:"That’s why your goal as a salesperson is to build relationships — whether that’s in person or online."}),(0,a.jsx)(s.A,{children:"But how do you turn LinkedIn connections into genuine, trusting relationships?"}),(0,a.jsx)(s.A,{children:"In this lesson, Alex reveals his three principles for building trust on LinkedIn, plus a foolproof three-step method for how to succeed along the way."})]}),transcript:`I'm Alex Boyd, and every time I post on LinkedIn, I make $13,000 dollars.

I'm the founder and CEO of a B2B marketing agency called RevenueZen and a software company called Aware. 

When I started my first company in 2017, I had no idea what social selling was. Then one day, I got an email that changed everything: “I saw your post. We should talk.” 

And it clicked. LinkedIn, if done right, can create serious pipeline.

There are ways to stand out, ways to form relationships that transform into revenue. There are steps you can take to build trust so that prospects come to you. 

You don't have to be a guru. You don't have to have ten years of experience. You don't have to pretend to be anything other than who you are right now. 

I know, because I’ve spent the last six and a half years fine tuning this process into actionable advice you can start practicing today—to build your credibility and your pipeline.

If you’re on a sales team trying to hit quota, if you’re leading that sales team, if you’re an entrepreneur trying to grow your business… 

…if you’re not using social selling, you’re leaving millions of dollars on the table.

My LinkedIn activity has brought in over five million dollars of revenue for my businesses—and I’m going to teach you exactly how I did it.

———

My very first role as a salesperson was at a publicly-traded brokerage firm. And, being brand new to sales, I thought ‘well if I’m going to ask people for money, I should at least engage them in a substantive discussion.

So I’d spend the first five to ten minutes of calls focused less on the sale, and more on the subject matter. 

And to my pleasant surprise, this strategy worked. People reasoned that the product must be pretty good because I knew what I was talking about, and because I was taking the time to really listen to them, to understand their goals, and to share everything I knew on the topic in a way that helped them. 

I ended up Rep of the Month at that brokerage firm for six of the first twelve months I was there.

But I had no idea that what I was also doing was building the foundations for what would become my social selling playbook. 

Because whether in the real world or online on LinkedIn, people buy from people they trust. As a salesperson, you should be spending less time building your prospecting automations, and more time building relationships.

Social selling is a way to build relationships online—a way to showcase your knowledge on specific topics and have open discussions with others about it. A really simplified definition I like to use is that social selling is about Helping People Publicly. 

But I get it—with over 930 million people on LinkedIn, how do you stand out? How do you start forming meaningful relationships that can eventually turn into revenue? 

There are three key principles that have guided my approach to social selling every single day and led me to success.

First, everything I do is focused on demonstrating credibility. I don’t talk about things I don't know about, and I avoid certain common mistakes that people make that detract from their credibility. Now, if you’re hearing this and you’re just starting your career, that doesn’t mean you don’t have credibility. We’ll get into that later.

Second, I highlight customer results. I spend a lot of time trying to answer the question that most people have, which is: can I trust Alex and his company to solve my most burning pain point? 

And the final thing that sets my strategy apart is I slow down my interactions with people. I'm much more likely to suggest a meeting in the next quarter or two than to beat people's door down for a meeting next week. We’ll talk about why and get into that later too. 

So… here's my credibility in this topic, here's how others have benefited from it, and—once those first two capture people’s attention—here’s how we turn conversations into pipeline.

These 3 key principles should guide your approach in every interaction you have, and help shape your mindset about what social selling is and what social selling isn’t.  

In this course, I’m also going to teach you a 3-step method for how to succeed at social selling. That’s engaging with others, posting high-value content, and taking interactions offline. 

Following these three steps, along with our three guiding principles, is what’s going to start generating pipeline for you.

As you start leaving comments and posting high-value content—as you start demonstrating credibility and highlighting customer results—you’ll see people start to reach out. You’ll also open the door for yourself to send outbound messages that prospects will actually want to respond to. 

I’ve taught this methodology to hundreds of sellers, who have closed millions of dollars in new business and gained clarity on how they should be approaching LinkedIn. Whether you’ve been in the business for a while, or just starting out, this course is for you. You can succeed at social selling, I promise, and I’ll show you how.
    `},{title:"The power of commenting",wistiaId:"jb8rvhlkkx",length:"6:24",deepLink:{color:"purple",heading:"Convert LinkedIn prospects into pipeline with Apollo",linkText:"Try Apollo for free",url:"/sign-up"},description:(0,a.jsxs)("div",{className:"flex flex-col gap-6",children:[(0,a.jsx)(s.A,{variant:"h5",children:"Alex once had a single well-placed comment lead to a $40,000 purchase order within just a few hours."}),(0,a.jsx)(s.A,{children:"Never underestimate the power and revenue potential of commenting on other people’s posts."}),(0,a.jsx)(s.A,{children:"In this lesson, you’ll learn:"}),(0,a.jsx)(i.A,{color:"purple",items:["Whose posts you should be engaging with","Common stale & robotic responses to avoid","How to craft a comment that actually stands out","Real-life examples of comments that build trust","A simple yet powerful habit to start growing your network"]})]}),transcript:`So let’s say you’re brand new to social selling on LinkedIn. Where do you start? 

Well the easiest place to start, and the place where you should start, is to simply engage with other people. And you do this primarily by commenting on their posts.

Now, why am I making an entire video on comments? Can leaving a comment be that easy to mess up? And my answer is yes.  

The reality is: most people are doing this step of social selling wrong. They don’t know who they should be engaging with or what to say in a way that actually builds their credibility and their business.

There’s power and real revenue in effective commenting. I have clients who got to know me and what I do simply by reading the comments I leave on other people’s posts. I’ve even had a single well-placed comment lead to a $40,000 purchase order within just a few hours of the prospect seeing my comment! This is a critical step in your social selling journey, so don’t skip it.

Now, before we talk about what to say in your comments, let’s talk briefly about whose posts you should be commenting on. 

Your LinkedIn network can be divided into three categories: your prospects, your close personal network, and then your broader audience.

Your prospects are people who fit your target buying persona and who you want to have buy from you. This one’s easy. They are your primary purpose for using LinkedIn, but they’re not the only ones you need to pay attention to.

Your close personal network is the people that LinkedIn was originally created for you to connect with—people you know or have worked with. 

Now, these are the people I actually spend the most time interacting with on LinkedIn. In fact, two thirds of my company’s LinkedIn referrals come from my close personal network. So even though they’re probably not going to buy from you, their connections are going to see the conversations you’re having with them. So don’t ignore this group.

And then third, your broader audience. These are people who aren’t your ideal customer, who aren’t people you know, but they still follow you, they like your posts—they help boost your post engagement, which isn’t a bad thing. It’s a social proof signal.

Your broader audience is not a strategic group of people for you to be interacting with a lot, but the second group—your close personal network—is.  With the whole goal at the end of the day being to network and book meetings with your direct prospects.

The thing I want you to take away from all this is that most people on LinkedIn are not going to buy from you, and that’s okay. The last thing you want to do is treat your close personal network or broader audience transactionally and miss out on the actual commercial benefit from engaging with them too.

Now the next question is, how do you engage? What do you say in your comments?

As I’ve mentioned, social selling at its core is about helping people publicly. Leaving valuable, insightful, clever—whatever personality traits you have—comments that represent who you are and your credibility on other people’s posts. 

But most people don’t do this. Most people leave really bad comments that are boring, unprovocative, or unclear in their credibility.

So let me show you what not to do. Take these posts for example.

Talk about stale. The two most common ways to not stand out are to say things like, “spot on” and “awesome post” OR to use ChatGPT to write it. These sorts of comments can actually be worse than saying nothing because they’re just noise, and leave your level of credibility unclear at best, and damaged at worst.

The other thing you don’t want to do: if somebody posts about their honeymoon in Iceland, don't respond to their post saying, “I saw you had a honeymoon in Iceland. I'd love to sell you business solutions." That’s now how normal human beings talk, it’s cringey, and it’s just not going to work.

So what does a better comment look like?

There is no script for good comments, but they are generally thoughtful, not desperate, and of course, show credibility.

Take this one for example.

I love what Jim says here.

“Eric, love your thoughts, and exciting to see how much you are digging in. Tim Ferriss had a great quote along these lines, “A person’s success in life can usually be measured by the number of uncomfortable conversations he or she is willing to have.”

I can tell this is a good comment not because of what he said, but because of how the post author, Erik, responds. When you leave comments you want to have people remember you in a positive way: “Hm that person gets it. They understand me” in a very small way. You don’t have to leave your master treatise of what your business is—this isn’t the place for it. What you’re trying to show is a little slice of credibility.

Here’s another example.

Hila Segal posts “what about polls like ‘what is your favorite ice cream flavor?’” This comment was written when LinkedIn Polls were all the rage, so it made me laugh.

This is a subject I’ve talked about a lot so I respond to her and in a very on-brand fashion for me I state a bold opinion. “Brand is not built by mere clicks and engagement but by credibility.” So what I’m doing is sharing an opinion that could be debated by marketers. It’s more memorable. And it shows I have an opinion that’s born from data and experience—and that’s why it’s a successful comment.

Last example.

My good friend Amy Volas saw a post I shared and said “This is incredibly helpful data, Alex. May I ask, where did you get this from and how often does this change (if you’ve been keeping an eye on the data)?”

Now this is a little preview of what’s to come. Because as you start posting—which we’ll talk about in the next lesson—sometimes you’ll get questions. People may ask you to go beyond your post and to share more insights.

One thing I hear often from people who are new to social selling is, ‘well, I don’t want to give away the secret sauce’. Imagine if you were to call a doctor or a lawyer to ask them a question, and they said “welllll I could tell you, but I don’t want to give away my secret sauce”. That’s going to be a HUGE red flag. On the other hand, if they were to give you a super insightful answer before you’ve even discussed retainer, they’ve built an enormous amount of credibility already, right?

It works the same on LinkedIn. So go above and beyond, be thorough and give more answers than they even asked for. 

That’s what I did in response to Amy’s question. I went into depth about where I got the data from and shared some more insights I thought she’d find helpful.

So… you’re going to write comments that are thoughtful, relevant, and build credibility. You might share a bold opinion, you might share a quote, you might answer a question with data. Whatever you do: your goal is to stand out. And with how many bad comments are out there, it’s not as hard to do as you might think it is.

Here’s the sales mastery habit you can start doing today:

Leave just five comments a day. Open up your LinkedIn feed, find five opportunities to comment on either your close personal network or direct prospects. This should take you less than 10 minutes per day. You can download the LinkedIn app, open it up between meetings, walking the dog, whenever. If you want to up your game and do up to 20 comments per day? Go for it.

The overall goal of this is to get to know your network, and have them get to know you.

    `},{title:"Posting high-value content",wistiaId:"s5tx6bgrkf",length:"7:10",deepLink:{color:"purple",heading:"Convert LinkedIn prospects into pipeline with Apollo",linkText:"Try Apollo for free",url:"/sign-up"},description:(0,a.jsxs)("div",{className:"flex flex-col gap-6",children:[(0,a.jsx)(s.A,{variant:"h5",children:"While commenting is a great start, publishing your own content takes your social selling strategy to the next level."}),(0,a.jsx)(s.A,{children:"Posting can be intimidating. But whether you’re a sales newbie or a seasoned pro, everyone starts somewhere. Why not start now?"}),(0,a.jsx)(s.A,{children:"In this lesson, you’ll learn:"}),(0,a.jsx)(i.A,{color:"purple",items:["How to gather ideas and get creative with your content","What most posts look like (and why they’re terrible)","Alex’s three tips for writing posts that stand out","How to advertise without advertising","And more!"]})]}),transcript:`You can grow your network on LinkedIn a ton by simply commenting and engaging. But to really maximize the value of social selling as a strategy you have to start practicing step two of our social selling method: publishing your own content. 

Now the first reaction I get from sales reps to this is fear. “Well if it's my content, I can be judged. I can be thought of as not knowing what I'm talking about.” 

But everybody who knows what they're talking about once didn't. Everyone started somewhere.

If you’re feeling short on ideas… go talk to product marketing. Go beat information out of your founder and CEO. Listen to prospect calls and gather insights. Just get intellectually curious, and remember that you talk to way more people than your average customer does. So you do have interesting insights to share and information to pull from if you just get creative.

The good news for you is that your content has a really good chance of standing out… because most people on LinkedIn aren’t posting, and if they are, most of their posts suck. They’re bland, boring, and don’t provide value.

Your posts shouldn’t. Your posts should always be relevant, strategic, and authentic. This is also the time to demonstrate credibility and highlight customer results, like we talked about in our 3 key principles.

Let’s look at a few examples, starting with a post that doesn’t perform well, and why. 

An Account Executive shared a post with some basic tips for stopping phishing. It’s got an image marketing created for him, and it links to his company’s blog. 

This is what most posts look like. It isn’t terrible, but it’s mediocre at best. 

The problem with these types of posts is that they don’t build up any credibility. People are going to see that and skip over it because all he did was share something somebody else wrote and there's no good reason to talk with him in particular.

My first tip for effective posting is to add meaningful context. Maybe if he told a story about a time a business owner they were working with changed their habits in such a way that phishing was reduced. It could be a story, a set of KPIs, an outcome. 

My second tip is to provide value right in your feed. Don’t link off to your blog or anywhere else if you can. Most people aren’t going to click it anyway. This should be your content, your voice. 

Let’s look at a few examples of what effective content looks like.

This was posted by Parry Headrick, the founder of a PR firm called Crackle PR. 

And everything above the green line is what a viewer sees before clicking “see more”.

What I love about this post is that it’s got a great hook. The first few lines of your post need to get people to want to click ‘see more’ right? This post does that. 

“Flashback to the B2B tech PR playbook of 2005.”

He’s using a technique I like to call ‘old way/new way’—speaking to the old, ineffective ways of doing things (in whatever industry you’re in) and then speaking to the best practices of today.

And notice he’s providing a lot of value directly in his post—not making people click out of it.

Another example.

This is a post by Josh Braun, a coach and prominent sales influencer on LinkedIn.

“I made a mistake. Someone in Prague ordered 24 sets of my sales objection flashcards. The problem?”

Another compelling hook, right? People love hearing about mistakes. So when you make a mistake and recover from it, talk about it!

But the other thing I love about this post is he’s exemplifying a technique I call ‘storytelling to sell’. He’s advertising without advertising. This story was a brilliant way to create brand awareness about the fact that he sells sales objection flashcards.

And, notice that both examples I’ve shown you are pretty lengthy posts, but they’re thoughtful and compelling. One of the most common things I see people do wrong with their content is stick to a total of five lines max. I want to encourage you to unpack your stories—tell us what you did, what it felt like, how your customers reacted—give me something to connect to. I guarantee you can't do that in less than 20 words.

Last example. This is one of my posts.

My hook talks about doubling conversions per month from SEO. This is something that people in my market—which is VPs of marketing and founders of b2b saas companies—care about. And it’s going back to two of our core principles: demonstrating credibility and highlighting customer results.

I also used an image. Images are a great way to showcase customer results in a way that gets someone to stop scrolling and look at your post. Does your product help with sign ups? reduce incidents? increase efficiency?—there’s almost always a way you can use an image to showcase these results. 

One other tip for effective posting…

I see a lot of people start their content by writing a brief summary of everything they know about the industry. I encourage you to resist that temptation. Treat each post as a tiny little slice of your story and what you know. You could write an entire post about something a customer said on a discovery call when they were nervous about moving forward with your product, or an entire post about one interesting insight you got from product marketing.

Point is: Don’t share everything you know all at once. Take 10 seconds of a conversation and unpack it in 300 words. You’ll get more bang for your buck spreading out your experiences vs. posting all your best insights on day one and ending up watering them down.

Another common question I get asked is ‘which format is best to post in?’ And my answer is, there are no rules… other than to mix it up.

A text post, a video, an image, a PDF you found, a selfie with your cat—it can be anything. In general, I like to use text the most because people read faster than they watch, but video is great for unpacking complex topics. It’s perfectly fine to experiment with formats and topics—the takeaway is to just make sure you’re not getting too repetitive with anything and to pay attention to what’s working for you.

SO, now you’ve seen some examples of content that are relevant, strategic, and authentic. You’ve seen examples of content that demonstrate credibility and highlight customer results. Now it’s time to put it all into practice.

The sales mastery habit you can start implementing right away is to start publishing once a week. 

Don’t think for one second that you need to post every single day. I don’t. I post once, maybe twice per week. The volume of your content is not nearly as important as the consistency and quality of it—for both LinkedIn’s algorithm and your audience.

So choose a day of the week, stick to it, and don’t worry too much about getting everything right off the bat. It’s going to take practice and commitment, but I promise you it’s going to be worth it.
`},{title:"Navigating inbound conversations",wistiaId:"i2qp0v9h73",length:"6:09",deepLink:{color:"purple",heading:"Convert LinkedIn prospects into pipeline with Apollo",linkText:"Try Apollo for free",url:"/sign-up"},description:(0,a.jsxs)("div",{className:"flex flex-col gap-6",children:[(0,a.jsx)(s.A,{variant:"h5",children:"Time to turn the online buzz into real-world results."}),(0,a.jsx)(s.A,{children:"You’ve engaged thoughtfully with others online. You’ve posted valuable content. Now people may start reaching out to you as a result."}),(0,a.jsx)(s.A,{children:"What then?"}),(0,a.jsx)(s.A,{children:"In this lesson, you’ll learn:"}),(0,a.jsx)(i.A,{color:"purple",items:["Why slowing down interactions speeds up productivity","When to stop ‘selling the meeting’","How to ask clarifying questions","Real-world examples of Alex’s tips in action","And more!"]})]}),transcript:`Let’s talk about step three of my social selling method—taking interactions offline. 

Now—to get to this point and to do it effectively, you can’t skip steps one and two. Engaging with others and posting high-value content are what help create interest around you, your company, your solution. This buzz is what’s going to properly set the stage for these offline conversations to occur.

These offline conversations are incredibly important. They are, quite literally, where the money’s at. Because the private one-on-one relationships that you build offline are the core of social selling. This is where your pipeline is going to come from.

Now, there are two ways these offline conversations are going to start happening for you. 

One is the inbound leads that will come to you as a direct result of your posts or your comments.

And the other is the outbound direct messages you’ll be sending to prospects.

The way I’m going to teach you how to navigate these two types of opportunities is not by sharing a series of scripts or templates, but rather by walking you through a few examples of how this has happened and might happen in the real world.

Let’s start with your inbound leads.

So inbound leads, again these are people who maybe saw something you posted or a comment you left and decided to reach out to you as a result. 

The first social selling inbound win I want to show you is a six-figure-ARR agreement with a B2B SaaS company that was sourced from my posts. 

Right before he reached out, this is the post he had just seen.

It starts with “Just asked one Series A CRO we work with what the revenue numbers have been like in the 12 months since Covid. I’ll share his growth formula below.” 

So I started with a hook, I highlighted customer results, and I showed an image of one of the metrics for my agency that we track—which is the number of keywords ranked organically that are target for the customer, and clearly that number is going up. Someone can infer from this that RevenueZen and I are credible on this topic, which is what this post was designed to do.

What happened next? Well, here’s what the prospect said:

“Hey Alex, I know I introduced you to Ben but turns out we may need your services as well. What are the types of SEO services you provide? We’re currently with an SEO agency that isn’t hitting their projected deliverables. So actively evaluating other options…”

First thing I do is thank him for his referral. 

Now what most sales reps will do at this point is they’ll say “let’s set up a meeting”. Your sales process should not be as simple as “once someone is interested, I get them in a meeting”. Not necessarily! You want to make sure the meeting is going to be good.

This is where our third key social selling principle comes into play of slowing down your interactions.

Now, what do I mean by that? Well instead of saying “up for a call this week?” I slow down and ask some clarifying questions. 

So I ask him this:

“What outcomes are you going for? We cover a wide spectrum of SEO work, from technical audits to content development to link building.”

He says “I’ve seen your posts about exponential growth in quality web traffic, so that’s the overall goal - I’m game with whatever routes we need to take to get there.”

So he’s definitely seeing my post content and inferring from that that it’s credible, which is a win. 

What I do next is start the discovery process. These are some common questions that I would ask someone, for our SEO services at least.

At the end I say, “Or we can jump on a call and start from the beginning. But I’m happy to scope out your current situation in more detail in advance if you’d like.”

So what am I doing here? I’m communicating to him that my time is valuable and I’m not just trying to have our team jump into a meeting right away. I’d rather we meet once we’ve done some research, which involves him answering some questions.

What I also did at this point, was I sent him an email with an introduction to someone on my team that could help him, because I don’t want him to have to remember to manage his LinkedIn inbox. I’m trying to make this as easy as possible for him to respond and for us to have a productive meeting.

Well, he did respond, and we ended up winning the deal, which as I mentioned, was a  six-figure-ARR agreement.

So one main takeaway from this example…
Once someone is interested, stop ‘selling the meeting’ and start doing the discovery work.

That’s going to be better than just trying to get a meeting right away with anybody. If you’re setting up meetings left and right with anyone that expresses interest, that communicates that your time isn’t valuable and that you’re desperate to lock in a time.

Another takeaway is to make it easy for them to respond to you, like I did by sending him an email. In this case I grabbed his email right from his LinkedIn profile using Apollo’s chrome extension, which you can find in the chrome web store.

Let’s look at one other example of what an inbound lead can look like as the result of an effective post.

Take a look at my hook. “This is the biggest mistake SaaS marketers make when thinking about SEO:

I’m ‘twisting the knife’, as it were, and going after the status quo my ideal customers—marketing leaders—are a part of. This increases the likelihood that someone will take that step of reaching out to me. And it worked. I got this message from the CEO of a company:

One again, notice how my first response to him isn’t desperate, I’m slowing down the interaction, and I’m not ready to set up a call until I have a little more context first.

Well, because I asked for it, I got some amazingly insightful context. 

Now I knew it was a good fit to set up a meeting, with the goal of just getting to know each other more.

This ended up becoming an amazing client for my company with a six-figure annual contract value. We have still been driving good results for them to date, after helping them grow 40% annually within the first year alone of working with us, with no outside investors.

Inbound leads are going to be an amazing source of pipeline for you. And they all stem from the trust you build through leaving engaging and insightful comments & posts.`},{title:"Starting outbound conversations",wistiaId:"k0e13j1hle",length:"5:21",deepLink:{color:"purple",heading:"Convert LinkedIn prospects into pipeline with Apollo",linkText:"Try Apollo for free",url:"/sign-up"},description:(0,a.jsxs)("div",{className:"flex flex-col gap-6",children:[(0,a.jsx)(s.A,{variant:"h5",children:"If you want to maximize your impact as a social seller, you need to be proactive."}),(0,a.jsx)(s.A,{children:"That means reaching out to best-fit prospects through direct messages. In this lesson, Alex will show you how to make these connections feel natural and authentic."}),(0,a.jsx)(s.A,{children:"You’ll learn how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Spot unusually good prospects",(0,a.jsxs)("span",{children:["Utilize the power of"," ",(0,a.jsx)(h,{href:"https://knowledge.apollo.io/hc/en-us/articles/5130064363661-Use-Job-Change-Alerts-to-Update-Contacts",children:"job change alerts"})]},2),"Set up meetings in a pressure-free way","Craft concise & compelling direct messages","And more!"]})]}),transcript:`Alright, so we spoke about how to navigate interactions that come to you from your comments and posts. Now let’s talk about how you can take the initiative to start offline conversations. You’ll do this by sending direct messages to prospects who seem like they could be a good fit for what it is you offer.

I often look for prospects that are an unusually good fit: for example, they are in a very similar stage and industry as one of our best case studies, or I have a good relationship with someone on their team, or they used to be a customer of ours and then moved to a new company and got a promotion.

The first example I’ll show you of an outbound interaction is from a time I used a customer job change alert to smoothly set up a discovery call. 

Now, before we get into it, if you’re not already getting customer job change alerts—I suggest you do so. Whenever one of your prospects, or decision makers on one of your customer accounts changes jobs and becomes a prospect somewhere else, those people are three times more likely to buy from you than anyone else.

My favorite tool to use for job change alerts is actually Apollo, since you can also grab your prospects’ email addresses, phone numbers, and other key information at the same time. 

Now, back to my example. Here’s how this went down.

I direct-messaged this person saying “hey good to see you finding wonderful new opportunities. You just popped up in my feed and I believe you were involved in some of our demand gen work while you were with your last company, right? Hope the first few days of your new roles are going well.”

He responded with “Great to hear from you. Thanks for the well wishes on the new role - so far I’m enjoying it. Hope all is well on your end too.”

Okay, this is friendly. But he’s not jumping at an opportunity to hop on a call with me, but that’s fine. I’m slowing down our interaction. I say:

“Love to hear that. You leveled up for this one right? How does it feel being the director?”

I’m thinking about what he’s going through on his end. He was a manager, and now he’s director level. I’m guessing he’s feeling pretty good about that. 

He says “Yes I’m enjoying the additional responsibility. I loved working with Olivia and was very comfortable in my role but it was time to take the next step.”

I say “I’ve been there, for sure.” And then, after slowing down this interaction, asking some questions, treating this person as a human, not just a buyer—then I say…

“Would love to catch up in a month or two - how does that sound? Once you’re situated.”

And he says “Sounds great, I’d love to stay in touch so please feel free to reach out any time”

I say okay “I’ll make a note to sync up with you later in the fall”

Now, I tell him I’m going to sync up with him in a month or two, not a day or two. Again, slowing down our interaction.

Six weeks later, I saw his company had just gotten acquired, which gave me a reason to reach out, so I said:

“Hey congrats on the acquisition. Hope you had a few shares. Feel like catching up on Wednesday the 17th? If so, I’m flexible in this time range…” I put it in his time zone and named a specific day. 

He says “good to hear from you. Wednesday works for me. Looking forward to catching up.”

Great! I pull his email from Apollo, and - we’ve set up a meeting!

A few key takeaways from this interaction:

I didn’t jump right into asking him for a meeting. I put myself in his shoes and had authentic interactions. And then I took the pressure off by slowing down our interaction.

The thing I love about asking someone for a meeting in the coming months or even quarters, is that if they’re available and want to meet with you earlier, they’ll show their interest and say “actually can we meet next week?” And if they’re not interested or they need more time, they can just say “yeah I’d love to meet with you in a month”. 

Here’s what you’re doing with that. You’re setting up meetings that put no pressure on them and you’re helping out future you. I love helping future Alex. Future Alex has tons of pipeline because of what present Alex is doing today.

Now, this next example I’ll show you is going to showcase how to use a well-placed DM, or direct message, to source a meeting.  Here’s the conversation transcript, it’s pretty quick.

I said “Hey I’ve been following your company for some time. I was Director of Sales @ inDinero from 2015-2017. Thought it’d be interesting to chat with you about what you’re looking to do with growth.”

Now, because the company that I worked at was in a very similar space to this person’s company, I felt fine about cutting straight to it and asking for a meeting. To do anything else might have come across like I was being indirect - not what most CEOs want. It turned out that I was right: two minutes after I messaged him, he responded, “your background seems highly relevant”. 

Which it is! So a takeaway from this already is to go where your expertise is most valuable. You’ll get the best responses from that.  And this is the CEO that responded—not a manager, not a director—this is the founder and CEO. 

So this is where I want you to place most of your DM and outbound effort—small, high touch, thoughtful things like this. Obviously this didn’t take much time to write, or that much time to find.

Again, look for opportunities where you or your company have extremely-relevant expertise, track record, or relationships. If you spend the majority of your time on opportunities like this, you won’t need nearly as much pipeline in order to hit your goals.
`},{title:"Nailing the meeting request",wistiaId:"edsz1wfbs9",length:"4:59",deepLink:{color:"purple",heading:(0,a.jsxs)("div",{className:"flex max-w-[350px] flex-col",children:[(0,a.jsx)(s.A,{variant:"captionMonoLarge",children:"NEXT"}),(0,a.jsx)(s.A,{variant:"h4",children:'Watch "How to Use Apollo & LinkedIn to Prospect"'})]}),linkText:(0,a.jsxs)(s.A,{children:["Go to",(0,a.jsx)("br",{}),"course"]}),url:"/academy/learn/how-to-prospect-on-linkedin-with-apollo-extension"},description:(0,a.jsxs)("div",{className:"flex flex-col gap-6",children:[(0,a.jsx)(s.A,{variant:"h5",children:"How you book meetings can make or break your social selling success."}),(0,a.jsx)(s.A,{children:"In this lesson, Alex dives into best practices for asking prospects for meetings."}),(0,a.jsx)(s.A,{children:"Discover a couple of killer scripts and learn Alex’s top tips for requesting meetings in a way that's effective, smooth, and far from annoying."})]}),transcript:`I wanted to spend a few minutes at the end of this course sharing some best practices I’ve learned about a very critical piece of your social selling funnel.  
It’s the moment when you’re asking a prospect for a meeting. Whether this moment is the result of your outbound efforts or inbound leads, the way you ask for a meeting can be what makes or breaks your pipeline. So let’s make sure you get it right.  

I want to start by sharing this post written by Zach Barney, who at the time was a VP at a company called Vehlo. He says “as someone who gets pitched a lot, and also as someone who manages salespeople, here are a few of my personal pet peeves.”

And the first one he mentions is “making the prospect work for a meeting that you want by shooting them over a calendar link. I'm a fan of leaving calendar links in the signature in case it's easier for them. But don't try to sell me something, and when I respond with mild interest, make me adapt to YOUR schedule.”

Now, what he's saying here aligns with a lot of what we've talked about in the course already. 
Giving someone a calendar link before they’re ready won’t work, you’ll just annoy them. Instead, stay present, slow down your interactions and listen actively to gauge interest.

I want to show you a couple templates you can use when asking for meetings. I usually don't like teaching with templates because these things aren’t always black and white, and it depends on the situation. But I’m making an exception for this because I think it’s that important to get this one small piece of the social selling process right.

Here’s a couple templates for you to draw inspiration from.

The first is “happy to chat more about this if you like. Do you have a calendar link I can use to book with you? Alternatively, here's mine. Wednesday afternoon is pretty flexible for me, for example.”

What this does is it lets a prospect know that you respect their time. You’re giving them the option of sending you their calendar link first. To make it even easier for them, you name a specific range on your schedule. You want them to think, ‘oh this will be super easy’ before they click your link. 

Another variation of this is “if it makes sense to dive into this further, I'm pretty flexible next week on Tuesday after 12pm PT if that works for you? Or, here's my link if it's easier for you to find time.”

Again, this makes it really easy for them to book. It lets them know a specific time range, and then a link they can use if that’s easier.

There’s a few takeaways we can gather from both these templates.

When asking for a meeting, pay attention to your prospect’s location and time zone. If you're not sure where they are, feel free to clarify with them, or name it in your time zone specifically, so they're not confused. If you are in California booking a meeting with somebody in Memphis, Tennessee, for example, you better know that they are in central time. 

The goal is to eliminate any confusion or unnecessary back and forth. Which leads me to my next point. 

We want it to be as mentally easy as possible for someone to book time with you, right? So look at your calendar first and offer your prospect some open time slots. What you're doing is you're saying, I've thought of this. You don't need to wonder when I’d be available to chat because I’ve already looked that up for us.

Third, make it physically easy for someone to book a time with you and send a calendar link. There is some debate out there of people thinking calendar links are annoying. They’re annoying if you send them to someone who isn’t expressing interest, like our friend Zach Barney said. Otherwise, you’re helping reduce mental and physical friction by allowing your prospect to just click a couple buttons and be done with it.

The goal of all of these tips is to roll this meeting out on a silver platter with white gloves. Do as much work upfront as you can to provide a frictionless experience for your prospects and they’ll conclude that your solution is equally frictionless. So figure out their time zone, give them your open time slots, send a calendar link and fill in the gaps with whatever else feels appropriate to make things easy for that prospect. 

———

We’ve covered a lot in this course. I want to end by saying this: if you find yourself still having questions when you’re leaving comments, writing posts, or sending messages on LinkedIn—you know… should I write this? should I not comment that?—it all ties back to our three principles of social selling. If you’re demonstrating credibility, if you’re highlighting customer results, and if you’re slowing down your interactions… you’re doing great..

If you practice the sales mastery habits I gave you—leaving five comments per day and posting once per week—you’re doing great. These actions alone will start generating plenty of interactions for you to work with. 

They may sound small, but remember—you’re looking at the face of someone who’s made over five million dollars from LinkedIn, doing these small actions every day. And if I can do it, I promise you can too. Good luck!
`}],d=[{title:"Intro: A new way of thinking…",shortDescription:"Learn the blueprint for outbound success—delivering the right message, to the right person, at the right time.",wistiaId:"1tjiafezqo",length:"2:57",deepLink:{color:"purple",heading:"Nail your outbound & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"In this inaugural lesson, Josh introduces the blueprint for outbound success—honed through years of optimizing sales processes for companies of all sizes."}),(0,a.jsx)(s.A,{children:"The blueprint is simple: deliver the right message, to the right person, at the right time."}),(0,a.jsx)(s.A,{children:"It’s time to stop blasting out templated emails with no real rhyme or reason. Sales isn’t actually a numbers game—but you’ll have to watch this lesson to find out why \uD83D\uDC40"})]}),transcript:`In this course, I’m going to give you a tried-and-tested framework for evaluating, optimizing, and automating your outbound sales process.

    We’ve developed this course after talking with dozens of world-class sales leaders, founders, and revenue ops professionals, and by combing through Apollo’s proprietary data from over three million users to find the strategies and tactics that are most effective.
    
    We’ll cover how to build a repeatable, scalable, effective outbound sales program that revolves around three core fundamentals—delivering the right message, to the right person, at the right time—so your team can focus on what they do best (and what sales is all about at the very core of it): building relationships and solving problems. And so you as a leader can deliver consistent results to your company.
    
    I’m Josh Garrison and I’ve spent most of my career optimizing sales processes for companies of all sizes—from one-person startups to multi-billion-dollar publicly-traded companies and everything in the middle.
    
    And now I work at Apollo—the world’s premiere end-to-end sales platform—so I’ve had a behind-the-scenes view on literally hundreds of companies' sales processes. And the one thing I’ve found again and again is that nothing stays the same.
    
    What used to work stops working. And without a consistent, rigorous framework for evaluating and optimizing your outbound process, performance starts to drop, open rates fall, and reply rates tank. You try to replace that lost performance by adding more volume—making more calls, sending more emails. And more often than not, it just makes it worse.
    
    Now, you might be thinking to yourself, “Shut up, Josh. I don’t need this nonsense. Our outbound program has been working for 5 years just fine!”
    
    And maybe it has…but, if you think about it, the way we buy things has changed dramatically. Consciously or subconsciously, as buyers, we’re now conditioned to expect ads for goods and services that are tailored to our specific needs and interests.
    
    Don’t believe me? Look at the valuations of Alphabet and Meta, and the ever-growing amount of money spent on digital ads that rely on a treasure trove of buyer data.
    
    My wife just had a baby. Her Instagram feed is covered in products for newborns. Because that’s what’s relevant to us right now. And instead of being creepy, it’s way more useful and relevant. And we’re way more likely to buy something than if her feed was just a random assortment of things people think we might want. That’s how people buy today, in their personal life and at work. It’s what we expect. 
    
    But outbound sales has been stuck in the past. We’re still blasting out templated emails with no real rhyme or reason, caught in that old mentality of ‘sales is a numbers game’. 
    
    There’s a new way of thinking, one that prioritizes data to deliver that perfect message to the perfect person at the perfect time. Because sales isn’t a numbers game—it’s a math game. And there’s two sides to the equation: who you go after and how good you are at it. And if you optimize both sides of that equation, you’ll deliver outsized results. 
    
    And I’m going to teach you how to do it.
    `},{title:"The targeting framework",shortDescription:"Identify the “who” of your framework and hone in on the 3 personas that will level up your outbound.",wistiaId:"b3ds2witid",length:"7:36",deepLink:{color:"purple",heading:"Nail your outbound & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"80% of your success in outbound depends on who you’re reaching out to."}),(0,a.jsx)(s.A,{children:"Join Josh as he explains how to refine your targeting framework for maximum effectiveness (so you can book 25-35% more meetings \uD83D\uDE32)."}),(0,a.jsx)(s.A,{children:"You'll learn:"}),(0,a.jsx)(i.A,{color:"purple",items:["The 3 questions to ask when building out your targeting framework","The 3 most important personas you should be targeting","How to find the prospects most likely to buy","How to leverage data to determine when to reach out","And more!"]}),(0,a.jsxs)(s.A,{component:"span",children:["Ready to put knowledge into action?"," ",(0,a.jsx)(h,{href:"https://app.apollo.io/#/login",children:"Log in"})," ","or ",(0,a.jsx)(h,{href:"/sign-up",children:"sign up"})," for Apollo to get started."]})]}),transcript:`The first thing I look at when evaluating any outbound program is the targeting framework.

    Now, I'll start by saying there are probably softwares that can help you do this, but I'm going to focus on how to do this yourself manually in a spreadsheet. 
    
    Not doing this is a critical mistake a lot of sales leaders make. We get caught up in optimizing our subject lines and email copy (which, don’t get me wrong, is important, and we’re going to talk about it). But in my experience, 80% of your success is entirely dependent on who you’re reaching out to in the first place. If you’re hitting up the wrong people, it doesn’t matter how good your emails are—you’re never going to get anywhere.
    
    A targeting framework is just a clearly-defined list of all the types of people you or your team will be reaching out to, ranked in order of importance, and broken down by what factors indicate they’re most likely to be in the market for what you’re selling. We've included a template for how to do this in the resources section of this video for you. 
    
    While this step isn't super fun or sexy, it is incredibly effective at keeping your program on track because over time there's just a lot of chaos that happens in sales. Things change, and if you don't have a roadmap to follow, you can get in trouble. 
    
    Truthfully, most companies don't even do this. They don't have a proper targeting framework. Taking this step is immediately going to provide some clarity to you and your team on what to do next.
    
    Just by following this process, I’ve seen companies turn around a failing outbound program or get 25-35% more meetings booked from an outbound team they thought was already optimized. 
    
    The good news is, it’s actually pretty simple. We’ll start by asking three questions:
    
    Who is our ideal customer?
    How large is our total addressable market?
    How up to date is our understanding of each?
    
    Your targeting framework begins with your ideal customer profile— we abbreviate that as ICP—which is often boiled down to one individual persona, which can be a mistake because most often there’s actually multiple people you have to successfully sell to bring a deal through. A lot of companies get this part wrong because who executives and product marketing think are your ideal customer is often different from who's in your CRM and who's actually signing the deals your team is bringing in. 
    
    So the first thing you want to do is audit every closed won deal your team brought in for the last 2 quarters and find:
    
    Who signed the deal?
    Who else was on the email threads or meetings you have with the client?
    Who was on the implementation call with your onboarding team?
    
    Once you do that, you’ll walk away with three distinct personas.
    
    The first are the people who sign the deal. We call this your Economic Buyer. They're the check writer. They're the big dog. Ultimately, they have to buy in, but they're not often actually using your product or service. Their team is using it. 
    
    And that's the second group. These are the people who are on the calls and on the emails.
    These are your Champions. These are the people who will directly benefit from what you're selling or whose team will directly benefit. And without them pushing for you internally, there's no deal. 
    
    Then there's that third group of people. These are your End Users and your implementers. These are the people who ultimately have to interact with you and with your product and your service.
    
    At this point, you should know a lot about each group of people—including their job title, the size of the company they work at, and the industry their company is in. The last step is to lay out for each of those three personas (Economic buyer, Champion, End user)—when is the right time for them to buy your product?
    
    And this is where I'd say most companies fail because they might know who the right people are, but they haven't really dialed in on when to reach out to them. This is a massive opportunity to improve. Because the reality is, only about 5% of all the people you could sell to—which we call your total addressable market—are even considering buying what you’re selling at any given time. 
    
    So if we think about it, the number one thing you can do to improve your performance is to only reach out to that five percent of people—the people who are actively looking for what you have.
    
    I’ll give an example: Let’s say you determined from your deal review that the Champion is the Director of Marketing at a 300-500 person technology company. And the absolute best indicator of if they need your product or not is they’ve just fired their content marketing team. That’s what you would add to your targeting framework. 
    
    Now you know not only WHO the buyer is, but WHEN they’re likely to buy. There’s a ton of data available to consider here: Did they visit your website recently? Are they hiring? Are they downsizing? Are they new in their job? Did they just get promoted? And so on. All of this stuff is available in tools like Apollo for you to consider when you build this out. 
    
    You’ll follow that process for each of the three personas (Economic buyer, Champion, End user), and now you have a solid foundation for your ideal customer profile, broken out in two dimensions: WHO they are and WHEN to reach out to them.
    
    To help you do this, we’ve created a guide, which you can download in the resources section of this course.
    
    Now we have to move on to identifying your total addressable market, which just means the total number of people in the world who you can actually get in touch with (meaning you have a phone number for them or an email address for them or a physical address for them, or all three).
    
    Now, there are a lot of methods out there for doing this. The old school way—you'd hire a research firm or a consulting agreement, but that's almost entirely unnecessary. 
    
    This is actually very simple. Using a tool like Apollo, take the criteria you laid out in your targeting framework for WHO each of your three personas are (we’ll leave aside the WHEN for now) and see how many results are returned that have either a phone number or have an email or a physical address. That’s your total addressable market. 
    
    Now you might find that your TAM is a lot smaller than you thought it was. Some companies have millions of contacts in their CRM and they assume that’s their TAM because why else would they be in the CRM? But when you dig into it, you find that it's full of duplicates, it's full outdated information, people who downloaded a marketing asset one time, and that's not actually your buyer at all. 
    
    Remember that middle word is key… total addressable market.
    
    Of course, this number is going to change over time as people change jobs, retire, start careers—which is why it’s critical to continuously update your TAM calculations, which you can do automatically with software like Apollo and others. And broadly speaking, it’s not necessarily a bad thing to have a smaller TAM than you thought because that means it’s easier for you and your team to focus on people who could actually buy your product.
    
    And with that in mind, we’re going to go one step further than 99% of companies, and we’re going to plug in the WHEN criteria from our targeting framework. Plug that into a tool like Apollo, and that’s how you find the subset of your TAM that you should prioritize at any given time. That is the most important number of all because this is the number you’re going to work backwards from to decide how big does my team need to be? What are their activity metrics? What should their output metrics be? And then that's going to lead you to determine what you can commit to deliver for the business and from your outbound program overall. 
    
    Now, we've just covered a lot of ground.
    
    With your brand new ideal customer personas laid out—rooted in the actual data of who buys from you—and with up-to-date total addressable market information, you can move on to the next step of the framework… which is your messaging framework.
    `},{title:"The messaging framework",shortDescription:"Craft messaging for each of your 3 personas by answering a series of questions for each.",wistiaId:"yg1xbgbot5",length:"4:47",deepLink:{color:"purple",heading:"Nail your outbound & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"Now that you know who you’re reaching out to, it’s time to figure out what to say."}),(0,a.jsx)(s.A,{children:"That means crafting messaging for each persona identified in your targeting framework."}),(0,a.jsx)(s.A,{children:"But… where do you begin? And how do you figure out what’s going to resonate?"}),(0,a.jsx)(s.A,{children:"Join Josh as he unveils the four essential elements to compelling messaging, empowering you and your team to stand out and get replies."}),(0,a.jsxs)(s.A,{component:"span",children:["Ready to put knowledge into action?"," ",(0,a.jsx)(h,{href:"https://app.apollo.io/#/login",children:"Log in"})," ","or ",(0,a.jsx)(h,{href:"/sign-up",children:"sign up"})," for Apollo to get started."]})]}),transcript:`It’s funny… even people who’ve done all the detailed work to produce a targeting framework often just have a couple of go-to email templates that they dump everyone into when it’s time to start reaching out. Meaning, you may have this super-specific time-based targeting… and you’re not using any of it in your messaging.

    Remember our three pillars: Right person, right message, right time. 
    
    We’ve taken care of the right person and the right time with our targeting framework. At this point, we need to evaluate our messaging framework and make sure that it aligns 1:1 with the targeting framework.
    
    Let's give a new example. So if our Economic Buyer is a VP of Finance at a 500-person company who’s currently hiring a comptroller, we need to clearly lay out what message is appropriate for them. 
    
    And if your champion is that comptroller in their first three months on the job, we have to clearly lay out what message is appropriate for them.
    
    This exercise will often reveal several areas for optimization where you realize the message your team is sending doesn’t align perfectly with the person you’re trying to sell to. 
    
    To be honest, that’s how most outbound teams work. SDRs are given leads or accounts to work, and then they’re more or less left to their own devices to figure out what to say to them. Of course, they’ll learn what works and what doesn’t over time, but that’s an expensive process. By taking this step, you can dramatically cut the ramp time for a new SDR and make your existing team far more effective.
    
    To help you in this process, we’ve created a messaging guide you can find in the resources section of this course that fits perfectly with the targeting guide from the previous video in this course.
    
    I do want to call something out. I’m not going to dive into the specifics of mastering email copywriting right now. We have courses on that. Sam McKenna has a fantastic course on her Show Me You Know Me\xae method, or you can see my video on Mastering Cold Emails with AI. 
    
    Messaging is something different than copywriting — it’s the high-level view of ‘what are we selling’. So, in this video, we’re going to focus on WHAT to include in your message and not HOW to word it.
    
    With that said, our message consists of four main parts:
    
    What does our product or service do for the person we’re reaching out to?
    What’s the benefit to that person?
    What’s unique about us?
    Why does it matter right now?
    
    This step is all about articulating those four things as clearly and plainly as possible for each of the personas in our targeting framework.
    
    Let’s run through an example. We’ll continue with our persona from earlier — an Economic Buyer who’s a VP of Finance at a midsized company and currently hiring a comptroller. And let’s pretend we work at a software company that makes a procurement platform. 
    
    Our messaging framework for this persona might look like this:
    
    What it does for them? Streamlines procurement processes across their whole company.
    Benefit for them? Can save their company tens of millions of dollars.
    Unique about us? Guarantee 100% successful implementation in 90 days.
    Why it matters right now? You need to set your new comptroller up to succeed with the right tools.
    
    By breaking this down plainly, we’re making it easy for ourselves and our team to know exactly what to message when they get a particular lead. And it’s important to do this for every persona you’ve created in your targeting framework. 
    
    If you audit your team’s emails and find that you’re sending the same message to every persona, you know right away there’s an opportunity to improve. This exercise will also help you interface better with your peers in marketing, product, and customer success because if you ask “what’s unique about us” and the answer is nothing… it’s time to come up with something together.
    
    By this time, if you’ve been following along, we’ve created a detailed targeting framework for each of the personas in our ideal customer profile, and we’ve now articulated what message will resonate with each of those personas.
    
    By doing all of this prep work, we’re setting ourselves up to succeed when it comes time to actually add leads to our sequences and start booking meetings. If you don’t do this upfront or take the time to do this periodically, things get out of whack. There’s a natural progression towards chaos, so by periodically reviewing your targeting and messaging frameworks, you’ll ensure your team is always putting themselves in the best position to succeed. 
    
    And as a sales leader? That’s really all you can do.
    `},{title:"Sequences for success",shortDescription:"Learn 3 out-of-the-box sequences that align perfectly with your targeting and messaging framework.",wistiaId:"542dju4oy5",length:"8:10",deepLink:{color:"purple",heading:"Nail your outbound & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"You’ve got the right people, the right timing, and the right message—now what?"}),(0,a.jsx)(s.A,{children:"This is when you put everything together into a sequence."}),(0,a.jsx)(s.A,{children:"Sequences help you standardize best practices across your team, reduce ramp for new hires, boost productivity for tenured reps, and (best of all) put more money in your pocket."}),(0,a.jsx)(s.A,{children:"In this lesson, Josh reveals:"}),(0,a.jsx)(i.A,{color:"purple",items:["What a sequence is and why you need one for every person/message combo","3 out-of-the-box sequence types you should have in your playbook","The shockingly common sequencing mistakes you should avoid"]}),(0,a.jsxs)(s.A,{component:"span",children:["Ready to put knowledge into action?"," ",(0,a.jsx)(h,{href:"https://app.apollo.io/#/login",children:"Log in"})," ","or ",(0,a.jsx)(h,{href:"/sign-up",children:"sign up"})," for Apollo to get started."]})]}),transcript:`By this point, we’ve built quite the spreadsheet. And now it’s time to take all of that work we’ve done with our targeting and messaging frameworks and make sure we have sequences built out in our engagement tool—like Apollo or others—that aligns perfectly with our targeting and messaging framework.
    If this term is new to you, a sequence (also called a cadence) is just a series of touchpoints—calls, emails, LinkedIn touches, whatever—that you define and that your sales team works through as they reach out to their leads. 
    So by this time, we have identified an ideal customer persona and a message that resonates with that persona, and now we need to create a sequence for each pairing of persona & message.
    Let’s continue our example from the last video. We’ve got our VP of Finance at a midsized company hiring a comptroller, we’ve defined a message for them, and now we’re going to build a sequence that we can put all of our VPs of Finance hiring comptrollers into. And we’ll do the same thing for every persona and message in our framework.
    You may be asking…”Why? My team is trained, they’re smart, they know what to do. They don’t need this!” 
    …yeah, they do. I’ll tell you why. 
    By following this structure, you’re going to collect an enormous amount of data that will let you continually optimize your sales process, help you standardize best practices across your team, reduce ramp time for new hires, increase productivity for tenured reps, and ultimately, get more of your reps to quota and put more money in your pocket.
    Now, many companies have already adopted an engagement tool, and they already have lots of sequences in play. But often, it’s anybody’s guess for who gets added to which sequence. Aligning your targeting, messaging, and sequence frameworks will instantly improve your team’s results.
    The other area people mess up with sequences is having the same goal for every sequence. If every sequence in your lineup is trying to get a demo… you’re doing it wrong. Obviously, you should have some sequences in your lineup whose ultimate goal is to get a reply that could lead to a demo. (Sam McKenna talks about that in her course, I talk about it in my email copywriting course—there are other places where we cover that in depth). 
    But in this video, I want to cover some other goals you should have in your sequences to give your team the maximum chance of building meaningful relationships with your prospective customers.
    Here are three out-of-the-box sequence types you should have in your playbook:
    One—inviting your top leads to VIP dinners. 
    Everyone loves a VIP dinner! And your most valuable leads—VPs, CEOs, Sr. Directors—are the least likely to reply to your ask for a demo. After all, they’re VIPs. So you should treat them like it! 
    Every quarter, you should be inviting your top 10 or 20% of leads to a VIP dinner. A CEO or VP who would never take a 15-minute demo with an SDR might just attend a dinner at a fancy steakhouse in their area. (I’m getting hungry just thinking about this.) I’ve held a bunch of great VIP dinners. I’ve found a lot of success with a 3-email, 2-call sequence, with a voicemail at each call. 
    Now, with this sequence, it’s not about selling your product. Remind your team of that! It’s entirely about inviting your best leads to an event where they’ll meet their peers in similar roles and do some solid networking. That’s value to them. And you meeting them in person? That’s value to you. There’s no better way to start a relationship. 
    I’ve seen a $5,000 VIP dinner result in $300,000 of closed won business within the next 30 days. You want ROI? There it is. 
    So if you’re dumping all of your VIP leads into a sequence hammering them for a demo… You’re leaving money on the table.
    Two—ask your potential champions for advice. 
    Early in my career, I heard a phrase that stuck with me: “Ask for money, get advice. Ask for advice, get money twice.” 
    One of your most important roles in sales is helping people solve problems. With that in mind, some of the best-performing sequences I’ve ever seen target the Champion persona—who tends to be a subject matter expert in whatever field you’re selling into. 
    A light touch (two or three steps max) asking Champions for advice on how to solve a particular problem one of your customers is facing is far more likely to get a genuine reply than just hammering them trying to sell your product. Especially if you’re an SDR! The reality is, you probably don’t know as much about the space as your leads do. Don’t try to cover that up. Lean into it! 
    The genius of this method is that if you do get a reply, you’re going to learn something about that account—however they’re solving the problem you’re asking about that can help you bridge that conversation into a meeting more squarely about whatever it is you’re selling. 
    As an example… I used to own a bookkeeping company that worked exclusively with marketing agencies. I had a sequence for agency owners that said:
    “Hey, one of my customers is struggling to find their profit or loss on a per-client basis. I know you’ve been in the game a long time. Do you have any advice for how to solve this?”
    This was a shockingly effective sequence that started a ton of conversations for me. And many times I’d get a reply back saying, “You know, I struggle with that too.” 
    That’s when I had them. That was my opening to set up a discovery call because my firm specialized in that exact line of work. So, if you’re not asking for advice… you should be.
    Three—asking end users for introductions. 
    One of the personas you identified in your targeting framework was the End User—the people who ultimately have to use your product or service. They don’t often have a lot of buying power, so most sales teams ignore them. This is a huge mistake. Just because they don’t write checks doesn’t mean they’re not important. I’ve seen a ton of success with sequences designed to garner an intro from the End User to their boss, or even their boss’s boss. 
    Again, this isn’t about selling your product or service per se. It’s about being honest with people about why you’re reaching out, telling them what you think you can do, and asking if they wouldn’t mind forwarding your email to their boss or introducing you directly. 
    Are you going to get a lot of ‘no’s’? Undoubtedly. But you’ll also get some yeses. And an intro like this is far more valuable than a regular cold email.
    There are a couple of shockingly common mistakes companies make with sequences. 
    The first is they’re too long. 
    Email filters are incredibly smart these days. If you send two or three emails to someone in a row without getting a reply, that spam filter is going to pick up that you’re not a trusted sender and your emails are going to land in spam, damaging your sender reputation as a whole. That’s bad news. 
    If your team’s outbound sequences include 5, 6, 7 emails in an attempt to squeeze every drop from each lead… stop it. If your messaging isn’t landing by the 3rd email, something is wrong either in your targeting or in your messaging framework. 
    The last area I most commonly see people mess up with sequences is in their cold call steps. 
    Cold calls can be incredibly effective, and we have whole videos on this subject with one of the best cold callers in the world. 
    But the gist of it is this: most salespeople don’t leave voicemails when making cold calls. This is a huge mistake. One thing the most successful outbound teams all have in common is… they leave voicemails. 
    At companies who commit to this, 17-25% of all the meetings booked come from voicemail callbacks. If your leads are important enough to call in the first place, they’re important enough to add to a sequence, and they’re important enough to leave a voicemail for.
    At this point, you have a targeting framework that dovetails to a messaging framework, which ties in perfectly with the sequences you’re using to reach out to people. We just have two topics left to building an incredibly effective outbound process—optimization and automation.
    `},{title:"The art of A/B testing",shortDescription:"Grab some tips for how to use data to continually inform your strategy and optimize your way to success.",wistiaId:"d7r6g56fao",length:"5:04",deepLink:{color:"purple",heading:"Nail your outbound & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"Optimizing your outbound requires strategic A/B testing. Unfortunately, most companies are doing it all wrong."}),(0,a.jsx)(s.A,{children:"Josh's methods have consistently yielded over 50% open rates, 25% reply rates, and 10% meeting rates for his sequences—and he’s ready to spill the beans on how he does it."}),(0,a.jsx)(s.A,{children:"In this lesson, you’ll learn:"}),(0,a.jsx)(i.A,{color:"purple",items:["How to avoid falling prey to false positives","The tried and true way to calculate statistical significance","Why testing two wildly different versions of your email is the way to go","And more!"]}),(0,a.jsxs)(s.A,{component:"span",children:["Ready to put knowledge into action?"," ",(0,a.jsx)(h,{href:"https://app.apollo.io/#/login",children:"Log in"})," ","or ",(0,a.jsx)(h,{href:"/sign-up",children:"sign up"})," for Apollo to get started."]})]}),transcript:`Once you have your sequences built or rebuilt, you’re now into the day-to-day maintenance of your outbound process. 

    One thing I’ve seen literally hundreds of sales teams mess up, even at big, established, successful companies—maybe even especially at big established companies—is optimizing their sequences. 
    
    This is where all the work you’ve done to date comes together, where all the data you’re collecting from your sequences and your targeting framework can be used to continually refine what you’re doing and inform your strategy going forward.
    At the heart of it, optimization is about using A/B testing to learn what specific message and offer works best with each of your personas. And believe it or not… most companies mess this up in any number of ways. Starting with not doing A/B testing at all. 
    This video is all about how to A/B test your way into an optimized outbound process. 
    Using these methods, along with the other things we’ve covered in this course, I’ve consistently seen over 50% open rates, 25% reply rates, and 10% meeting rates for my sequences—results that are practically unheard of and would blow most outbound teams’ minds. But it’s totally possible! It takes time to get there, but it’s extremely worthwhile to do it.
    Statistical significance
    The first mistake most outbound teams make when it comes to A/B testing has to do with statistical significance. Statistical significance is just a mathematical way to determine if a test has enough data to be considered valid. But many sales teams have more or less arbitrary rules for how to decide which variation of an email—A or B—wins. 
    One time I was asked to review a company’s outbound program. This is a successful company with a lot of sales reps and brought in a lot of money. I found that they had a few sequences with a lot of volume—thousands and thousands of sends in each sequence. But I noticed that each A/B variation they were actively using only had about 300-500 deliveries, and some of their previous variations had thousands of deliveries. 
    When I asked the SDR manager how they were determining success, they said “I wait til there’s 250 or 300 emails sent and see which one is the winner”. 
    This… is not the way. 
    But, this is how the majority of outbound sales teams approach optimization! They set a static number—500 deliveries, or 300, or 100—see which of the A/B variations wins, and go from there. But the problem is, this can present you with false positives. And you end up optimizing for a worse result over time—exactly the opposite of what you’d hoped to do! 
    To optimize properly, you need to calculate statistical significance for each A/B test you do and only determine a winner if you have a 90% or greater confidence interval. Now some software will do this for you. You don't have to do all the math yourself. If all of this is gobbledygook to you… don’t worry. We’ve linked to a few statistical significance calculators in the resource section of this course.
    Testing variation
    Another common mistake outbound teams make with optimization is they test too few variables at once. 
    I know, I know! A statistics professor somewhere just had a heart attack, and it’s my fault. What the hell do you mean? Isn’t the only way to A/B test to isolate one variable at a time? Well… yes, kind of. But also no.
    In the very beginning, when you’re spinning up a new sequence for one of your personas, or testing a new messaging framework, you actually want to run two wildly different variations of your email with different subject lines, different body copy, and different calls to action. 
    Now, you may be thinking—isn’t this going to confound our test? How will we know which variable was responsible for the better result? You won’t. 
    But the thing is… when you’re spinning up a new sequence or breaking into a new market, you don’t know what’s going to work. You just have your hypotheses, and your goal is to validate or invalidate them as fast as possible. Using this approach will help you determine which approach works better much faster. And once that initial A/B test is done, you can start to isolate each variable in subsequent tests and figure out which subject line, body copy, and CTA work best. 
    This may seem counterintuitive, but if you limit yourself to only testing one variable at a time, you’re also limiting the speed with which you can learn, especially when trying to break into a new market or persona for the first time.
    If you’re only optimizing on statistically significant results and you’re testing multiple variables at once for your first A/B test and then isolating variables one at a time, before you know it you’re going to land on a really well-optimized outbound program that’s producing consistent results for you and your team and performing better than you or your leadership team thought possible. 
    Now, you’re ready for the last step in this process: Automation.
    `},{title:"Automate to elevate",shortDescription:"Incorporate automation wherever possible so you and your team can focus on what matters most: building relationships.",wistiaId:"5x8702dqe2",length:"3:42",deepLink:{color:"purple",heading:"Nail your outbound & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"Despite the rise of AI, human touch reigns supreme in sales. But why not let robots handle the repetitive stuff while you focus on what truly matters: building relationships?"}),(0,a.jsx)(s.A,{children:"In this lesson, Josh covers a few automations you should have in place to get the most from your outbound program, including:"}),(0,a.jsx)(i.A,{color:"purple",items:["Sending a friendly congrats when current customers change jobs","Building lists and adding people to sequences","Adding inbound leads to sequences so you can strike while the iron’s hot"]}),(0,a.jsxs)(s.A,{component:"span",children:["Ready to put knowledge into action?"," ",(0,a.jsx)(h,{href:"https://app.apollo.io/#/login",children:"Log in"})," ","or ",(0,a.jsx)(h,{href:"/sign-up",children:"sign up"})," for Apollo to get started."]})]}),transcript:`Automation. Scary word.
    The good news is I can confidently say that the robots aren’t here to take our jobs. Yet. Probably. 
    Even with AI here to stay, there will always be a role for a human salesperson. Because no computer or robot can replace the value of a human-to-human relationship. 
    With that said, sales teams have every reason to automate as much of their outbound process as possible to free up as much time as possible for the sales team to do what only they can do: build those relationships. 
    Using modern sales engagement tools, it’s possible to automate a huge portion of the outbound process. And if you’ve followed the steps laid out in this course, you’re going to find combinations of targeting, messaging, and sequence structure that just work. Your goal at this point is to automate those things, so you and your team can focus on the leads that need complete personalization and on opening new frontiers for your business.
    I’m going to cover a few types of automations you need to have in place to get the most from your outbound program.
    One—when current customers change jobs.
    It takes a lot of work to get a customer. A LOT. But sometimes, you lose a customer through no fault of your own. People change jobs. It happens. When they do, you should automatically reach out to them and congratulate them on the new role and see if there’s an opportunity to do business again. This might sound complicated, but you can use the ‘Workflows’ feature in Apollo—called triggers in other tools—to do this automatically. And assuming you have good data to go off of, this is a tried-and-true automation that will lead to more business for you and your team.
    Two—automate prospecting and adding to sequence. 
    One of the most painful parts of doing outbound sales is the manual work required to build a list of people in your target persona, get their contact information, add them to a sequence, and then start going through your sequence tasks. Luckily, all of this can be automated. And for your tried-and-true, bread-and-butter targeting/messaging/sequence combos, you absolutely should. You don’t want your SDR team doing manual, repetitive tasks when the robots can do it for them!
    To do this, you’ll need to create some ‘if/then’ logic statements using a tool like Apollo’s workflows or Salesforce’s Process Builder. Basically, you can define your targeting persona and tell tools like Apollo that any time a new lead meets that criteria, to add them to the sequence for that persona. 
    If this sounds a little like techno-wizardry to you, we’ve included a link to step-by-step instructions for how to do this in the resources section of this video.
    The third automation is actually not about outbound sales at all. It's about inbound sales.
    We've focused on outbound sales, but you absolutely need to automatically route your inbound leads to a sequence. Any time an inbound lead comes through your website and requests to talk to your sales team, it's vitally important that you get in touch with them as quickly as possible, both with a call and an email. That's because the faster you get in touch with those people, the more likely they are to become customers. And if you don't get in touch with them quickly, they're going to go to your competition.
    We’ve covered three automations, but there are literally hundreds of automations you can create for your sales process. John D. Rockefeller had a quote that sums up how to think about it. To paraphrase, he said: Once you get good at your job, hire someone else to do it. Then, put your feet up and think of new ways to make the company money. 
    Once you get good at outbound, automate it. Then, put your feet up and think of new ways to make the company—and yourself— more money.
    I’m Josh Garrison. Thanks so much for spending your time with me. I hope you enjoyed this Apollo Academy course.
    `}],c=[{title:"Intro to Show Me You Know Me\xae",shortDescription:"Get to know the concept of Show Me You Know Me\xae and the woman behind it.",wistiaId:"frcgxtgia1",length:"5:00",deepLink:{color:"purple",heading:"Send better emails & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsxs)(s.A,{variant:"h5",children:["In this lesson, Sam sets the stage for what sales is really all about:"," ",(0,a.jsx)("b",{children:"building relationships"}),"."]}),(0,a.jsx)(s.A,{children:"You'll learn how Sam first discovered the power of hyper-personalized subject lines, and how viewing leads as people, not pocketbooks, was her key to skyrocket success."}),(0,a.jsx)(s.A,{children:"Most importantly, you'll get introduced to Sam's groundbreaking (yet super simple) technique for writing cold emails— termed Show Me You Know Me\xae—and learn how it can send your open and reply rates through the roof."})]}),transcript:`I discovered the power of personalization all the way back in 2010. I remember when I took my very first meeting with a C-suite. It was a Chief Marketing Officer at a law firm called McGuire Woods, and the gentleman was named Jim Durham. I was petrified of this first meeting, but of course, he went very easy on me.
    And at the end of the meeting, which I was overly prepared for, he said, "Listen, why don't you do this? Take a look at my LinkedIn network. Look at the people that I'm connected to and see who I know that you would wanna meet. And then send them an email, tell them that we know each other."
    And I thought, are you kidding? One of the really interesting parts about sales is we get these offers a lot and very few people take that person up on it.
    I went back to my office that night. I looked at Jim's network on LinkedIn, and I must have sent over two hundred emails to individuals.
    But the key that I did, what was really different, was that I used my subject line strategically. In the subject line of the email that I sent to all these individuals I said, "From a friend of Jim Durham"—front and center.
    The open rate was off the charts, and the reply rate was also off the charts. People were willing to take meetings with me just because I was smart to put something in my subject line that mattered to them.
    So it started this realization of the power of personalization in the subject line. And then I started to think, well, where else can I use this? That is where the concept of Show Me You Know Me\xae was born.
    —-
    Show Me You Know Me\xae is a phrase I first heard from one of my mentors over a decade ago. It's the art of understanding who your buyers are as people, who their companies are, and what space they're in.
    It is so rare that sales reps do research and come prepared—not only in emails, but also to their calls. That means the competition for you is low. The people that are reaching out to your buyers are not doing Show Me You Know Me\xae, and that puts you at a competitive advantage.
     
    In fact, McKinsey says only eight percent of companies personalize. Eight percent! But of those who do, over seventy five percent of them are seeing an increase in response rates, meetings booked, and—what we are all fighting for—pipeline growth.
    I can attest to that. When we put this into practice with a team of 22 BDRs, let me tell you what happened. (This was incredible, and I may have cried a little bit when we heard the results.)
    We had 22 BDRs that put Show Me You Know Me\xae into motion. Over the course of this period, what they did was send 500 emails—about 280 first emails and the rest as responses less than 48 hours after the first one went out. We got 127 responses and 41 meetings booked!
    Now if you know anything about averages, those numbers are through the roof. (Hence why I cried when I heard the results.) But that's one really great example of how putting this together for the masses of a team can really make an impact.
    Show Me You Know Me\xae has been so effective at getting replies that our clients have been lining up to learn how to do it and how to get their teams to do it, and we took it so far as to trademark the term.
    In this course, I'm going to:
    1) Teach you how to research your prospects in a way that's meaningful and not at scale.
    2) I will walk you through the examples of what Show Me You Know Me\xae should and
    should not look like.
    3) I'm gonna teach you how to write an email from beginning to end that stands out even to
    your highest value prospects.
    4) And finally, we'll talk about the concept of Show Me You Know Me\xae and how it extends
    beyond cold emails. How simply building authentic relationships can help you hit your quota and take control of your financial and sales destiny.`},{title:"The human, the company, the space",shortDescription:"Lay the groundwork for your perfect email by learning the art of in-depth prospect research.",wistiaId:"5w67vc5sjs",length:"6:09",deepLink:{color:"purple",heading:"Send better emails & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"This is where your Show Me You Know Me\xae journey begins!"}),(0,a.jsx)(s.A,{children:'The secret to writing a "perfect" cold email truly starts with investigating your prospect. But not just surface-level research—we\'re talking a deep dive into learning about them at both a professional and personal level (without entering the creep zone, of course).'}),(0,a.jsx)(s.A,{children:"In this lesson, Sam shares pro research techniques that go beyond just standing out—they make your competition look like they didn't even try."}),(0,a.jsx)(s.A,{children:"Join Sam as she reveals:"}),(0,a.jsx)(i.A,{color:"purple",items:["Exactly where to kickstart your research journey","The three layers of your prospect you need to understand","Common pitfalls to sidestep","How much time to spend in this research phase","And more…"]})]}),transcript:`I think part of what harms us from a sales perspective is that somewhere along the way, we forgot about the customer. We've designed processes to be self-serving as companies and as individuals: how we qualify a meeting, the hoops we make our buyers jump through in order to even speak to a sales rep, and so forth.
    Remember that people want to be seen as... people, not just as pocketbooks, not just as somebody with wallet share. I think what's so important is that we make a positive impression with our very first outreach. This is where Show Me You Know Me\xae begins.
    For starters, I would encourage you to go up in the executives that you're reaching out to. Don't just reach out to one or two levels above you, but really reach out to the most meaningful and sometimes scariest title.
     Start to research them. And my first go-to place, of course, is always LinkedIn. I'm looking for information about who they are, not only as an employee of this company and others but also who they are as a human being.
    Almost every time I talk about this concept, reps ask me, “But what do you mean? Where do I start, and how much time does this all take?” So I want you to think about one thing first. There are three layers to how we can understand our prospects. Those three layers are thinking (again) about the human, the company, and their space.
    The human
    The first thing you need to understand is who your buyer is as a human being. That means, again, as I just mentioned, looking at their profiles on LinkedIn. Start with common connections, look in their headline, look in their about section—what can we find as common ground to authentically connect with?
    You also want to make sure that you're then doing your homework on the prospect as a professional. What do we know about this human being at his job or her job? What do we know about how long they've been there, how often they've gotten promoted, where they worked previously? Perhaps they had a completely different career to begin with that you can authentically tie yourself to.
    And finally, check your CRM. Where has this person showed up, if at all, in your CRM before? There is nothing more embarrassing than getting on a call and saying "Bill, have you heard of our product or our company before?" And then Bill kind of cringes and says, "Yeah. I've purchased your technology six times, and I also happen to sit on your customer advisory board." Eek!
    We wanna make sure that we show up in a prepared way so that our clients know we've done our research. And again, we stand out.
    The company
    Now, I get it. Sometimes you go to somebody's LinkedIn profile, and there's effectively a tumble weed going across it. There's no information, no picture, barely a headline. So what are you supposed to do next? Where does your research begin then?
    What I would tell you is look into the company. Go to their website. Take a look at their resources, their press releases, their values, the principles they have. Do they raise money for charity? What is going on with the organization that you can reference?
    More often than not, you'll also find that the executives have done podcasts, they speak at conferences, they write articles, they're part of press releases directly on the website. There is so much that you can pick up from that.
    
    And finally, has this company been a client of yours before? Were they a client and they churned, but now they're coming back? And why? Is this the nineteenth opportunity that you're opening up and that you've never been able to get over the goal line with this particular client? This is all information you should know. Not only is it helpful for you to be prepared in such an awesome way for you to stand out, but it's incredibly helpful for you to know to qualify and to move opportunities forward.
    The space
    The third layer you wanna think about with getting to know your buyers is who they are in the space that their company is in. Now this means the vertical, right, thinking about specifically what's tied to the vernacular of their company, Do they talk about products? Do they talk about leads? Do they talk about professional services in a different way?
    Now if I go into a law firm, I can't go in and talk about sales and leads. I have to use words like clients. I have to use words like business development. So it's really important that you make that shift.
    You might think, what if I have a territory that has nineteen verticals in it? Am I supposed to memorize them all? And what I would tell you is one, maybe eventually, not out of the gate. But first and foremost, think about what your lowest hanging fruit is vertical-wise. Where do you already have a great footprint and where can you keep expanding? Or where has a new vertical shown promise that you can take and run?
    When I think about, again, that legal example, that's exactly what I did. When I became a sales rep, I found that we had three or four of the largest law firms in the world working with us, and none of the others.
    I took it as an opportunity to interview those individual firms, understand why they used us, understand why we were important, learn the language, and then turn that three or four into forty three in less than two years.
    So we've talked about doing research on your prospect at the human level, at the company level, and then at the space and vertical level. That can sound like a lot to some sales reps. But what I always say is just be realistic that this is a brand new muscle you are building, and it takes time.
    Think about how long it might take you to run a mile out of the gate, thirty-five minutes? No. Just kidding. A little bit less. But every time you try to run it, you're going to get a little faster and a little faster.
    So give yourself thirty minutes for your very first Show Me You Know Me\xae email. I know that seems like an eternity, but I promise it will speed up. It will take you less time each and every time you do it, and you'll start to get where it's around five to seven minutes each time.
    Just remember, especially when it comes to high value leads, quality always trumps quantity.`},{title:"The don'ts of personalization",shortDescription:"Learn the common mistakes that often sabotage cold emails so you stand above and beyond the competition.",wistiaId:"wx04ee9o8d",length:"4:49",deepLink:{color:"purple",heading:"Send better emails & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:'"I love your dog, First Name. Want to buy my stuff?" Nope, us either.'}),(0,a.jsx)(s.A,{children:"From inauthenticity to poorly-done personalization at scale—it's important to become familiar with the sorts of emails executives face every day in their mailbox."}),(0,a.jsx)(s.A,{children:"In this lesson, Sam will teach you the most common (and sometimes downright hilarious) mistakes too many salespeople make… so you can avoid them like the plague."}),(0,a.jsx)(s.A,{children:"Sam's insights will guide you on the path to crafting emails that are remarkably authentic, add value, and, most importantly, get a reply."})]}),transcript:`Before we move on to putting your research into an actual email, I wanna quickly touch on a few
    things you should not do when it comes to personalization.
    I can't tell you how many times I've seen an email that looks something like this. Subject line says “Go Noles". Now... I went to Florida State, so they're trying to pull out some Show Me You Know Me\xae and talk about my alma mater's mascot. But here's how the email goes.
    “Hey, Sam. Saw you went to Florida State. Go Noles! Do you have a problem with this organization?”
    And then they go on to try and pitch me their product. There is absolutely no authentic tie to what I do, why they mention the Noles, or what history they have with it. That's when I see that, and I go, “Ugh, not again.”
    You also wanna make sure that you don't swing too far the other way—like starting to get into research that's done off professional sites. So perhaps looking at a Yelp review or a Pinterest board or something on their Facebook page that's private and that you happen to find. So maybe starting a subject line with “Love Your Family Beach Pictures”, or perhaps you referenced something from a Yelp review that you saw that they wrote in 2009.
    You want to make sure that the Show Me You Know Me\xae you reference is either pulled from their professional LinkedIn page and has something that they've shared with their professional network or that you're pulling it from a company page, a podcast, or an article that they wrote that relates to their work.
    When you think about the other things you don't wanna do when it comes to Show Me You Know Me\xae, one of them is what's called personalization at scale. I am sure you have seen this in your inbox, and if not, your executives certainly have. It's when you look at a subject line, and it reads in a way that could be written for that person... and five hundred of their closest friends.
    Think about things like “Quick Question” or “Meeting on Tuesday?” or “Need more pipeline?”— things that have no relevance to that person and what is called personalization at scale is what we want to avoid.
    I see this kind of email all the time too:
    Subject line: Kimberly, want to collaborate?
    “Hi Kimberly, I found your profile on LinkedIn and I wanted to reach out.”
    This is a prime example of what we don't want to do. I want you to think about these two things together. The subject line and the first sentence are what's called your preview text. And what you're going to see is that that particular executive has gotten that email... and thirty just like it. There's nothing that helps it stand out and cut through the noise.
    Further, when you think about something like this in that preview text, it's what that person sees before they even open up the email. And it says, “psst this is a sales email!”. So it encourages them not to even open it, but to automatically delete it. This kind of personalization at scale is not effective. It doesn't relate to who this person is as an individual, and it shows that we didn't actually make any sort of effort.
    Here's another example. If you look at the subject line, it says “If you're struggling with budget cuts, you're not alone.” So we just shortcut to exactly what the value prop is of the email, and we simply say,” hey, this is a sales email”, front and center.
    Now, one last example. Subject line: Passionate about poverty alleviation? “Hi Samantha, I see that you’re passionate about poverty alleviation. Curious to know what got you interested in this and how you stay involved?”
    This could be one of my favorites simply because there's so much to pull apart, but let's look at a couple of things. First of all, it talks about poverty alleviation.
    If you look at my profile, or if you look at our website, you'll see that we do raise money for poverty alleviation. We're really passionate about it. So it could be a great Show Me You Know Me\xae, except it says nothing about how it relates back to them. It simply asks me a little bit of an awkward question about how I got into it. I guess we got into it just by being good humans? But I digress...
    Look at the rest of the email.
    “Found Sam Sales Consulting last night when going through the rising companies in Washington. You’ve surely noticed the massive spike in recently-founded companies in District of Columbia. Which brings me to my point, Sam...”
    First and foremost, it separates out our company name, “Sam Sales”. Ghat's not our company name. Another thing to think about is that they talk about the massive rise in consultancies in the District of Columbia... What does that mean? They're trying to pull something that relates to my business and relates to my location with absolutely no point. Right? Really important that we make sure that whatever piece of personalization we put in is authentically tied back to us and has a great point
    So my point in all this is that poor personalization can truly do more harm than good. Being inauthentic, getting too personal, or relying too much on personalization at scale will showcase that you didn't do your homework and showcases that potentially time with you will not be well spent.
    There's a happy balance you want to strike, and a way to write emails that sound human, sound authentic, and truly add value. I'll show you how to write those kinds of emails, next!`},{title:"Crafting the perfect email",shortDescription:"Discover the winning techniques Sam uses to tackle each and every element of her cold emails for optimal replies.",wistiaId:"2lszosq4j6",length:"9:05",deepLink:{color:"purple",heading:"Send better emails & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"Emails that use the Show Me You Know Me\xae method boast an impressive 43% open rate and 20% reply rate. Now it's time for you to join the ranks."}),(0,a.jsx)(s.A,{children:"Join Sam as she spills the beans on the secrets to writing a cold email that actually gets a reply, including how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Craft a subject line that makes no sense to anyone but your recipient","Embrace the unconventional in your first sentence","Write a solution-based value prop","Avoid calendar links and the all-too-common “Do you have 15 minutes tomorrow?” trap","And more!"]}),(0,a.jsx)(s.A,{children:"TL;DR: You'll learn how to strike the perfect balance in crafting emails that sound authentically human and, dare we say, add actual value."})]}),transcript:`The industry average open rate for emails to execs is alarmingly around six percent. And if you wanna be even more terrified, the average reply rate is point nine percent—not even a full percentage point.
    But when you compare that to Show Me You Know Me\xae open rates, here's what we look like: an average open of forty three percent and an average reply rate of twenty percent. That's incredible! And it's unheard of in the sales world, which is unfortunate. But also... not so unfortunate, because what that means for you is there's a massive opportunity for you to stand out in executives' inboxes simply by putting some thought into what you write.
    Let me show you what an executive's inbox usually looks like. It's not pretty. Right? “Available to talk?”
    “Can I make an intro?”
    “Quick introductions?”
    “Quick question.”
    There's so many subject lines that are all generic. They say personalization at scale, and they secretly say, “pssst, I wanna sell you something”.
    You can do so much better than this. And you've got to do better than this if you expect anyone to open, read, and reply to your email. Now let's get into exactly how you're going to do this.
    The subject line
    The subject line is the most important part of your email. This is where you have just a few seconds to capture the attention of the CEO, VP, or whatever executive you're reaching out to. The subject line could look something like this:
    ΠΚΦ + Nothing Shall Ever Tear Us Asunder (Except Detention Fees)
    Now when you read this subject line, I want you to again reflect. Does the subject line make any sense to you? If you say no, then we did our job correctly.
    This email was written specifically for the Chief Logistics Officer of Tory Burch—a multi-billion dollar company, and here's what happened. In less than ten hours of that very first email being sent, the person responded and said, “Your email stood out in a sea of emails that I get every single day”.
    Now here's a really cool thing about this subject line as well. This is where you can start to scale this. What other executives do you have that were in that same fraternity? Think about how this
     is a great opportunity to use that same subject line and to use it on multiple executives while still making it look like it was just for them.
    A couple of other tips. Think about how to break up your subject line. Shorter is not necessarily better. You don't have to adhere to less than four words, and you can use “+” signs as a great way to break up the verbiage in your subject line.
    Referencing those exact tips, here's an example of a subject line that would work on me:
    Switzerland + Le dip Cheeseburger + [ your company name ].
    I want you to think about the subject line. Again, it makes absolutely no sense to you, and it makes absolutely no sense to anybody that you know, except for me. I'm originally from Switzerland, I was born just outside Geneva, I live in Washington DC, and I often wax poetic about the cheeseburger at Le Diplomat. And your company name doesn't make any sense to me, but the first two things do. So it's at least going to get me to open up the email and see what it is that you have to say about the incredible Show Me You Know Me\xae that you did on me.
    The first sentence
    The second most important part of your email is the first sentence. Your subject line plus your first sentence is what's known as the preview text, and that's primarily what determines if your email gets read.
    There are two different approaches that I'd recommend trying here. At my company, #samsales, our go-to first sentence is this.
    “Hi, Bill. We have yet to be properly introduced, but I'm Sam McKenna, and...”
    Now a couple things here. A lot of people will say not to introduce yourself in the first sentence. It's a waste of space, they say. But here's where I differ in opinion. When you put together a subject line that shows that person that you know them, and you've done research, and you pair it with, “we have yet to be properly introduced”, what you're signaling to somebody is that perhaps we should have been introduced, and that you do know something about them.
    Now another example is to go right into the Show Me You Know Me\xae. Don't waste any time. You might say something about their dog in the subject line, and then say something like this in your first sentence.
    “Bill, I saw your recent post about your adorable furry companion Sprinkles, and...”
    And then tie it back to your own dog. You'll see some of the most high-level executives often post about their dog. So a great way to open up the door with them is to reference those animals, and again, to think about an authentic tie right back to you.
    
     The value proposition
    Your value proposition is not what you do. Most emails that we see say what the person does. Now that's a marketing email. So your value proposition is truly the challenge that you solve. What is it that you do for that particular buyer and how can you help them?
    I see this kind of value proposition all the time:
    “Saw you're hiring. We see most CROs struggle because they ignore this challenge we see... want to hear more?”
    Now we see emails like this because we're often encouraged as sellers to write short, short, short emails. But again, I beg to differ here. Longer is better, and here's why. We have to convince our buyer that time with us will be well spent.
    When you state something specifically that you can solve for them, then think:
    ● What is the next big objection?
    ● What is the buyer thinking?
    ● And what's their rebuttal?
    You stating that you can solve a challenge for them isn't enough. You might get them to either object, say “we don't need that”, say “we already do that”, something like that. So we've gotta get around that objection to begin with.
    Let's take a look at an example that someone on the #samsales team might send to a prospect. Let's say our value proposition starts with this: “If you're anything like our clients, you see your usage rates of LinkedIn Sales Navigator hover around five percent of your licenses. We can train your teams and bring that number up.”
    I also know that my most common objection is: “Eh, we have a customer success manager at LinkedIn. We don't need this.”
    So if they said that to me, or if they responded to me in that way, what would I say back? This is what I want to write succinctly in the first email:
    “You likely have a customer success manager at LinkedIn, but rather than having them teach you what buttons to push, our team will teach you how to use this platform to sell in the same way that Sam did when she was an executive at LinkedIn for her teams.”
    So what that does for that buyer is, “Huh, oh, so maybe there is something not only that Sam can do to improve our rates, but to change how we use the platform.”
    The close
    And finally, what you thought would never come, the end of the email. How do we close it?
    
    For starters, with any outbound email, and I would tell you even referral emails where you get introductions that are inbound, do not use a calendar link.
    Why don't we wanna do this? It's presumptuous, it's a little rude, and it puts the onus on the individual to schedule time with you. Here's the other thing that I don't like about it. Now that individual is working around your calendar, instead of you working around theirs.
    Another thing to avoid is writing something along the lines of, “Do you have fifteen to twenty minutes tomorrow to chat, or would Monday at 1 PM work?”
    Again, the reason for this is it's presumptuous in terms of a short timeline tomorrow, or it gets too specific, and it allows the buyer to say no to Monday at one, and then you're left in a pattern of chasing them.
    What I would tell you to do instead is something that looks different and that looks like this. Simply say, “Do you have time over the next week or two to learn more? Let me know what works for you, and I'll send a calendar invite along accordingly.”
    Nobody sends scripting that looks like that. So not only will you be different, but you'll take their timing and their calendar into effect, allowing you to schedule the call, you to control the timing, and even for you to rearrange things on your calendar to accommodate them.
    I've just walked you through—beginning to end—exactly how to structure emails that will get replies from high value prospects. If you want to see a few examples that put it all together, I encourage you to check out the resources section of this course.
    I also want to challenge you to start putting this all into practice. Set a goal for yourself. Perhaps it's just twenty emails per week. Remember, quality over quantity. But start practicing these emails writing with this new script and following these new techniques that I've taught you and I promise you will start seeing results immediately.`},{title:"Structuring your sequences",shortDescription:"What if you don't get a reply? Sam answers all your questions about what to do next.",wistiaId:"fcig26r2h8",length:"6:56",deepLink:{color:"purple",heading:"Send better emails & close deals faster with Apollo",linkText:"Sign up for free",url:"/sign-up",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"So you've written the perfect cold email—now what? When do you hit send? And what if your email masterpiece is greeted by an orchestra of crickets?"}),(0,a.jsx)(s.A,{children:"Fear not. Sam's got answers to all those questions."}),(0,a.jsx)(s.A,{children:"This lesson is chock-full of insights into the art of email sequencing. You'll learn:"}),(0,a.jsx)(i.A,{color:"purple",items:["How to time your research with your first and second touches","What to do (and not do) in your LinkedIn touches","The art of delighting your prospects (instead of pitch slapping them)","How to tune into triggers to strike the right chord",'How to embrace rejection & nurture your "no\'s"',"And more!"]})]}),transcript:`A couple of questions I frequently get asked are “When should I send my emails and if I don't get a response, if I put all that time into my first email, then what do I do?”
    Now that I've taught you how to structure your emails, I want to give you a few pointers on how to address exactly those things and how to structure your sequences.
    With the first email, here's something unique that you can try. Do all of your research during the week, but don't send your emails until Thursday or Friday, particularly for high ranking executives.
    The time of day doesn't typically matter, but here's what I want you to think about. What's going to happen when you send that first Show Me You Know Me\xae email is you might capture their attention. You might get a quick open, you might get a quick read, but then something comes up
     that's going to distract them. So while your email made impact, perhaps it didn't get an immediate reply.
    So then what? Data shows that you get a significant increase not only in open rate, but in response rate, if you send the second email less than forty eight hours later.
    A couple of tips here, again, the opposite of what we most often see. First and foremost, do not change the subject line.
    Second, when you send this in less than forty eight hours, don't give them a second novel to read. You already killed it with your first email. So the second email is just to say, “Remember me? I'd really love a response”.
    So what we want to put content wise in that second email is very simple, and you can use any variation of this. We might say something like:
    “Hey, Josh. Wanted to quickly pop in and see if you've read my below email. I'd still be grateful for the chance to chat with you about how #samsales can support [ company name ].”
    So, to recap so far: day one is going to be your first email on a Thursday or a Friday. Your second email, your second touch, is going to come on a Saturday or a Sunday.
    Now your third touch or your fourth touch might come a couple days after that, and then another couple of days after that. Don't forget, while there's a lot of data that shows exactly what's perfect, we're also dealing with human beings who have different lives and different schedules and are checking emails in different ways. So don't be too afraid of the timing of when the third and the fourth and so on come.
    I want you to think about the fourth or the fifth touch, and that's usually where the LinkedIn touch comes.
    Now a couple of things to be careful of when I talk about the LinkedIn touch. First and foremost, a lot of people have built into their sequence, something that's called the “profile view”. I would tell you... cut this immediately out of your sequence, and here's why. That executive might only see the last five people who have looked at their profile. I promise you this doesn't impact your open or your reply rate, so cut it out.
    The second thing I would be mindful of is do not use InMails. This is something that was really popular in the early days of LinkedIn, and it was really effective because it was different. But we've ruined InMails by making them really spammy and really sales-y.
    So instead, create a LinkedIn connection. You are going to go to the person's profile, you're going to hit connect, or you will hit the three dots to personalize an invite, and simply add a script that looks something like this:
    
     “My name might look familiar as I've sent you a few emails. I would still be grateful or appreciative of the chance to chat with you about how #samsales can support [ organization name ]. If you're ever up for a chat, please let me know.”
    One really cool thing about this is this: you're going to stand out from the noise because you're actually going to use content and context in your connection request. What many people do these days is the opposite. They send a blank connection request, and then they do something called the “pitch slap”, where the person accepts the connection request, and they immediately pitch them in their DMs.
    Don't do this. When you are straightforward and you add context to your connection request, here's what happens. You communicate with the person that you've already tried the old school ways to get their attention. You might even send them back to your emails to read.
    But the other thing is they'll be able to look at your profile. They'll be able to humanize who you are, and they will most likely accept The great thing here is that sometimes they want to book the meetings with you.
    Other times, they simply say “thanks”, period, or nothing at all, period. This is your chance to be different. Send a reply when you get the “thanks” or the nothing in response and simply say:
    “Thank you so much for connecting with me. I look forward to staying in touch.”
    You will delight and surprise your buyer because you were doing something different, and you were not pitch slapping them. Now I could keep walking you through the exact sequence we use at #samsales, but the point is I wanna make sure is really clear is that you're not going to hit it out of the park with the first sequence.
    The whole idea is to A/B test. So create one, two, three sequences, and take a look at what works. Is maybe email three getting the most responses? Is it something about email eight that ultimately gets people to click on your marketing campaign or a link that you included for a webinar? What is it about that messaging that works? And then start to thread those things together. We're looking to create the ultimate sequence but we have to start somewhere and we have to start testing.
    Let's look at a couple of other things that typically happen.
    You might send a really great email that all of a sudden gets a few opens. Perhaps one's in Texas, perhaps something is in Detroit on a mobile device, and it's all pretty quick. That's what's called a trigger. And you want to use those triggers when you see these things happening in succession and use them to your advantage. Now you might consider even using a little self deprecating humor when you reach back to the person that you reached out to. I might say something like:
    
    “Josh, I see a few emails getting open in a few different locations. I imagine, and I'm hopeful that that means that there's intent by you and your colleagues and you're interested... or my email was really bad and you guys are talking about it.”
    Make sure whatever you say is authentic to you, but I think humor and authenticity can often go a long way.
    Another thing to think about is you might also get objections: “Thank you so much for reaching out”, “Now is not the right time”, “I'm not the right buyer”, “Please reach out to us in ninety days”—things like that.
    The thing that's wonderful about this is because you put the time into Show Me You Know Me\xae, you will more often get replies. Even if now is not the right time, and even if the person isn't the buyer, this opens a door to communication. You can connect on LinkedIn. You can keep in touch with them. And certainly, if they say, “We'd love to talk, just not right now”, this allows you to start nurturing and investing in the relationship versus just chasing them with spammy and personalized at scale emails.
    The key to keep in mind is that because you didn't use personalization at scale and instead used Show Me You Know Me\xae, you open the door to building better and more authentic relationships in even less time than you were doing before.`},{title:"SMYKM hacks beyond the inbox",shortDescription:"Learn how to utilize Show Me You Know Me\xae beyond their reply. *Bonus: Get a free discovery call script.",wistiaId:"pyocyh6vy2",length:"5:19",deepLink:{color:"purple",heading:(0,a.jsxs)("div",{className:"flex max-w-[350px] flex-col",children:[(0,a.jsx)(s.A,{variant:"captionMonoLarge",children:"next"}),(0,a.jsx)(s.A,{variant:"h4",children:'Watch "How to Send Cold Emails in Apollo"'})]}),linkText:"Go to course",url:"/academy/learn/how-to-send-cold-emails-in-apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"In this final installment, Sam covers what to do when you do get a response to a cold email."}),(0,a.jsx)(s.A,{children:"The reality is—Show Me You Know Me\xae extends far beyond the first email, and the very best salespeople in the world are the ones who recognize this."}),(0,a.jsx)(s.A,{children:"As we learned in lesson one, sales is truly about building relationships. And now Sam will share some tips for nurturing those relationships once they progress past the inbox."}),(0,a.jsx)(s.A,{children:"From meeting in person to a game-changing discovery call script, this lesson is the cherry on top to your cold email follow up."})]}),transcript:`We've talked about doing your research, writing that first email, building out a sequence for if they don't respond, but now let's get into what happens when you actually do get a reply. Now you've got the meeting booked. What do we do when we show up to that first call?
    As I said, Show Me You Know Me\xae bleeds through every part of your sales cycle—from the first email to when you've had a client for ten years. So it's really important that you do your pre-call research just as you do your research for an email.
    The discovery call
    When we think about the typical opening script for a discovery call, they're not great. So here's what I want you to think about as an opening script that you will hear us use on almost every single discovery call #samsales has with our prospects. Here's how we start:
    “Thank you so much for making time for us today. I could tell you a million things about #samsales: One... two... and three...”
    In this little section, I list three things that are related to that buyer persona. So I want to make sure that they're specific to their interests—specific to maybe things that they shared with me in advance of what they'd like to get out of the call—or things that are specific to what I typically talk about with that specific buyer persona.
     So again, “I could tell you a million things about #samsales. One, two or three. But I would love to hear about you first...”
    Now, this is where the Show Me You Know Me\xae kicks in. So you might say:
    “I know you recently had an acquisition.” “I know you're looking to double revenue.” “I recently saw that you replaced your CRO.”—Whatever it is that you learned about them and researched in advance is what goes here.
    And then you close it out with, “Tell me about your team and your challenges. What's the overall landscape like for you, if that's okay?”
    I want you to think about this in three parts:
    1) You share a little bit about yourself.
    2) You share what you know about them.
    3) And then you give them some breathing room to think about what they wanna share with
    you while asking for permission at the very end, “if that's okay”.
    What is amazing about this opening script is, first of all, it gets so much information out of them. Those buyers typically will respond with a big sigh (“Yeah, so...), and then they'll start to talk for two or three or nine minutes sometimes. And what's fantastic about this is while they're talking, they’re answering a lot of the questions that you might have in the beginning: do they have budget? what technologies do they use? They might answer questions for you to help you qualify the call before you've ever even asked a second question.
    The other thing that's fantastic about this is the question does not focus on features and benefits, which most of the calls do. This allows you to elevate your game and to ask questions about specific business challenges versus just products and features that they're looking to resolve.
    Meeting in person
    What happens though when we meet somebody in person, right? Not all meetings are happening digitally these days. So let's say somebody says, “I'd love to meet you for coffee, for lunch, for drinks”. What do you do that might be different in your preparation?
    If you are booking the lunch, drinks, or the coffee date, I would make sure that you make the reservation if you can.
    I once met a CEO for lunch, and when I went, I was unfortunately the latter of the person to get there, they showed up early, and I was seated with my back to the restaurant. Now what that meant is while the person kept talking and talking and talking and I really needed to go, I was left in a position of continuing to make small talk while looking around and trying to find the waiter. It was really awkward, I had to keep doing it, and I vowed to never do it again.
    
    So here are my tips. One, make the reservation. Two, add notes in the reservation details that say specifically when you would like the check to be brought, and to be brought to you. And third, make sure you show up early.
    Little things like this can make sure that it goes really smoothly, particularly if this is the first second time you're taking a meeting in person.
    –
    These are relationships you will hopefully keep for life. As people transition jobs, they tend to stay within the same vertical, and you probably will too, which means you will have these clients as they transition from one leadership position to another.
    From that very first email to how you talk to them on the phone, to how you present yourself in person, I challenge you to set yourself at an infinitely higher bar. By showing your buyers that you know them and by going the extra mile by focusing on quality over quantity, you're building an elite career as a seller—as someone who is different. Your open and reply rates will skyrocket. You'll make more sales in the end, and you'll get financial freedom. There is really no downside to making this effort.
    Remember to set a goal for yourself right now. Decide how many Show Me You Know Me\xae focused emails you want to send this week, and don't worry about how long you're spending on them. I promise the time will come down as you build this muscle, and you might be surprised at who you hear back from and how quickly.
    That wraps it up! Thank you so much for spending part of your day with me, and I wish you so much success on your sales journey.`}],g=[{title:"Intro to Conversation Intelligence",shortDescription:"",wistiaId:"kk42y3wno8",length:"1:51",deepLink:{heading:"Find and close your next deal in Apollo",url:"/sign-up",linkText:"Sign up for free",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"How does saving up to two hours a day sound? Or increasing your win rate by 26%"}),(0,a.jsx)(s.A,{children:"There are tremendous benefits of using AI to improve how you sell. Join host James O’Sullivan as he dives into how AI-powered call recordings can help you:"}),(0,a.jsx)(i.A,{color:"purple",items:["Ditch manual note taking and stay more focused on calls","Strengthen your discovery process","Track keywords, competitors, and objections","Craft hyper tailored post-call emails","And more"]})]}),transcript:`In this course, I'm gonna walk you through how to set up and use Conversations to improve how you close deals and simplify your sales process.

There have been tremendous benefits of using AI to improve how you sell. Reps that use AI to automate manual tasks are saving up to two hours a day. Sellers that use AI to inform their deals have seen their win rates increase by twenty six percent, and teams using Conversation Intelligence are reporting a twenty one percent increase in revenue. AI-powered call recordings is one of the few places you can set up one thing and see an impact in all three of those buckets.

But Conversations in Apollo does more than that. It's gonna help you out in a whole bunch of ways, big and small.

AI-powered call recordings will let you ditch the manual note-taking process. You'll be more focused on what the person's saying, asking better questions. It'll strengthen your discovery process. It'll help keep track of every time someone mentions a competitor or an objection, not only in a single meeting, but across all your meetings. It'll allow you to proactively multithread on those bigger deals with ease. It'll help you to craft hyper-tailored follow-up emails that are gonna be easy for you, and they're gonna wow your prospect. And there's a whole bunch of ways to get better at sales, to provide feedback, and improve your overall sales process.

So that's what this course is gonna cover. Let's get you set up with Conversations in Apollo. The next three videos are gonna cover setting up Conversations in your account, how to use Conversations to record your meetings, and using the AI-powered insights to improve how you sell and how many deals you close.

So join me in the next video. We're gonna get you set up with conversations in just a few minutes.`},{title:"Setting up Conversations",shortDescription:"",wistiaId:"vxwb0tsun8",length:"2:18",deepLink:{heading:"Like what you’re learning?",url:"https://app.apollo.io/#/conversations/recordings",linkText:"Use Conversations in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"Your AI-powered call recordings are just minutes away."}),(0,a.jsx)(s.A,{children:"But first, let’s get Apollo Conversations all set up. Follow along as James guides you through the process, step by step."}),(0,a.jsx)(s.A,{children:"What you’ll learn:"}),(0,a.jsx)(i.A,{color:"purple",items:["How to connect your meeting platform(s) (Zoom, Google Meet, & Teams)","Setting up permissions for automatic meeting recordings","Adding keyword trackers to capture key moments in every meeting","And more!"]})]}),transcript:`In this video, I'll walk you through how to set up Conversations in Apollo.

To set up Conversations, we're gonna integrate wherever you have your meetings, like Zoom, Teams, or Google Meet. We're gonna set your permissions, and then we're gonna add something called keyword trackers.

Follow along in your account. Let's do this together.

Now before you go get it set up, you just wanna make sure your mailbox is linked. If it's not or you're not sure, just click on ‘settings’ at the bottom left, ‘manage mailboxes’ at the top right, and you'll see if your mailbox is linked right here. If it isn't, click ‘link mailbox’ at the top right.

Once you're sure you've got your mailbox link (you need to do that so the Conversation has access to your calendar), click on ‘Conversations’ under win and close.

Once you're here, just click ‘set up Conversations now’. The first thing it's gonna ask is where you having your meetings? Zoom, Google Meet, or Microsoft Teams? You can connect one or multiple.

Start with the one you have most of your sales meetings in. For me, that's Google Meet. Because I'm signed in to Apollo with a Google account, integration is very simple. You just hit connect, and you're good to go.

Once you connect your meeting software, then you'll have to set some permissions. The first one being, do you want all users on your Apollo account to have their meetings recorded automatically, or do you want to manually add those users in the future? If there's multiple users already on your account, you can choose which ones should have their meetings recorded right down here.

And finally, you'll need to add trackers. Now keyword trackers are your way of telling Apollo Conversations what to be looking for in your meetings — words or phrases that when said, you want Apollo Conversations to track. There's prebuilt ones in here provided by Apollo that you can use or you can edit them as well. Any of these that you don't want set up, just hit ‘delete’. If you want to edit them, just hit the pencil. You'll be able to add more custom trackers once you're done with setup.

Once you finish with trackers, you'll see this pop up letting you know that you've set up Conversations, and you're good to get started.`},{title:"Recording your meetings",shortDescription:"",wistiaId:"0x1il9kp1j",length:"6:18",deepLink:{heading:"Like what you’re learning?",url:"https://app.apollo.io/#/conversations/recordings",linkText:"Use Conversations in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"Now that you’re all set up, it’s time to hit the record button."}),(0,a.jsx)(s.A,{children:"In this lesson, you’ll learn how to configure Apollo to automatically capture every crucial moment, ensuring no insights slip through the cracks."}),(0,a.jsx)(s.A,{children:"You’ll learn how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Set up automatic recordings, consent notifications, scorecards, & more","Toggle recording on and off & manage visibility","Record last-minute meetings","Filter and sort recordings for easy access and insights","Link meetings to deals for better tracking"]})]}),transcript:`In this video, I'm gonna walk you through how to use Conversations to record your meetings.

The first thing we're gonna do is hop into recording configurations. So you can set up which meeting should automatically get recorded versus which ones that shouldn't. I'll show you where you can find your upcoming meetings so you can toggle on or off if they'll be recorded or if other people on the team can see them. I'll show you where the meeting recordings live, how to associate them with deals, and what to do if you have a last-minute meeting as well. So let's hop in. Let's do it together.

So we're at the home screen. Before we click into Conversations, let's go to settings and check our recording configurations.

Just go to ‘settings’ and click on ‘Conversations’, and you'll see a few different menus here. The first one is ‘recording settings’. This is where you can tell Apollo which meeting should or shouldn't be automatically recorded. The first one at the top is gonna ask you, do you only want meetings with external participants recorded, or can it be any meeting? The next one's gonna be where you can place domains that you don't want recorded, whether it be a partner or a customer or a client that you don't want their meetings recorded or they've requested that. You can put the domain right here. The last question is, how long does a meeting need to be for Apollo to analyze it? You can throw a threshold here. It won't analyze anything shorter than that.

The next screen is ‘recording consent’. This is where you can let people know that they'll be in a meeting that's being recorded. The top is for announcements that will play in the meeting at the beginning of a meeting. The bottom will be for email notifications for internal, external participants, and you can set the text of that notification right here as well.

You'll have recorded users next and how to handle new users on the Apollo account. Do you want everybody that's added to have their meetings recorded, or do you only wanna have the ones that you manually add? You can see all the current users of Conversations below that and if there's any issues with the syncing of their information. You'll see something like this, ‘link mailbox’ with a warning if something's not working.

The last two screens you'll see are ‘trackers’ and ‘scorecards’. Now we went through trackers when we first set up Conversations. This is where you can come back if you wanna make edits, add new keywords or categories, or delete something you already have. Now a word of warning, if you don't have the tracker set up, you can't retroactively apply it. So it's better to put everything in you think you might want tracked early than regret it and put it in later. So if you think it's something you might be concerned about, pop it in. You could always make edits.

The last one here is scorecards where you can build out scorecards for people to grade each other's meetings, whether they're peers, managers, training department, whatever you want. You can create different scorecards by hitting ‘create scorecard’ up here, and then people can share their meetings to get feedback. I'll show you that in a later video.

Once you're done setting up your configurations, let's go back to the home screen and click on ‘Conversations’.

This is the Conversation's home page. You'll see some data at the top, but let's get straight to how do we know if our meetings are gonna be recorded?

Over here, you'll see your recorded meetings and my upcoming meetings. Let's click on my upcoming meetings. If you've synced your mailbox and calendar and you have upcoming meetings, you should see them here. You'll see a brief description of what the meeting is, how many people are gonna be attending, the date and time. And to the right, you'll be able to toggle on recording on or off. Blue is on. Gray is off. So if you wanna change that for any meeting, you can just pop over here and toggle that. The three dots will give you an option to set visibility to private if you don't want other people to be able to see these meetings in their conversations as well. Your recorded meetings will live right here. You'll be able to click right into them and see the full meeting recording, who was talking and when, and when screen share was occurring. You can speed it up if you'd like, go full screen, but everything is here for your meeting recording.

Meetings need to be on the calendar and synced over to Apollo for them to show up in ‘my upcoming meeting’. So if you have a last minute meeting or something that's not showing up here, you'll notice there's a ‘record now’ button at the top right. When you click that, you can pop in the meeting URL from Google Meet, Teams, or Zoom and send your Apollo recorder over to that meeting even if it's occurring in just a couple minutes. I've got a meeting happening just about to start, actually. So I'm gonna go grab the URL and pop it in here to make sure the recorder will come over. Go to the invite, grab the link. Pop it in, and hit ‘record now’. That'll send the recording bot to that meeting. It'll show up in your recorded meetings right here.

Now you're probably gonna have a lot of sales meetings, and you want to find them easily (not scrolling up and down a screen that has tons of meetings on it). You'll notice you can sort them at the top right, but you've also got filters you can use to find meetings for a specific company with somebody involved in those meetings, specific tags, trackers, or scoring. All these filters are available. If you don't wanna see them, you can always hit ‘hide filters’, and they'll disappear. Then the focus will be on your recorded meetings.

The last thing I wanna show you is how you can associate a deal to one of your recorded meetings. It's great having all the information related to a prospect and a deal that's in progress k. So you've got one source of truth. Everything from a cold lead to the meetings you're running and all the insights involved. You'll see, next to your recorded meetings, a little button to associate a deal. I had this meeting here with Sunny. I'm gonna hit ‘associate deal’, and I can search through my existing deals. Or if I haven't created one in Apollo yet, I can hit ‘create deal’ right there. I'm gonna select the one that I've already created and hit ‘apply’.

The details of that deal are now associated with this meeting. And when I go to my funnel and check that deal, I'll see this conversation and all the insights associated with it there as well.`},{title:"Turbocharging your workflow",shortDescription:"",wistiaId:"ln49riaxs9",length:"6:00",deepLink:{heading:"Like what you’re learning?",url:"https://app.apollo.io/#/conversations/recordings",linkText:"Use Conversations in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"From auto-reply emails to detailed call recaps, this is where AI transforms your sales game."}),(0,a.jsx)(s.A,{children:"Join James as he teaches you how to let Apollo Conversations do the heavy lifting, streamline your follow-up processes, and continuously improve your strategies — while you focus on closing deals."}),(0,a.jsx)(s.A,{children:"What you’ll learn:"}),(0,a.jsx)(i.A,{color:"purple",items:["Using AI-powered call recaps and Ask Apollo for instant meeting insights","Auto-applying insights to craft emails and track deals effortlessly","Sharing clips, tagging teammates, and creating scorecards for feedback","And more!"]})]}),transcript:`In this video, I'm gonna walk you through how to use AI-powered call recordings to turbocharge your business.

First, I'll walk you through your call insights — where AI recaps various parts of the conversation to make it easy to find anything you’re looking for. I’m going to show you one of the newest features — Ask Apollo — where you can ask the AI anything about your meeting and get an answer. We'll cover auto-reply emails to save you time there, sharing clips, tagging other people in scorecards, and playlists.

Follow along in your account. Let's do it together.

So we're on the home page. I'm gonna click on Conversations because I wanna show you some of the really cool things you can do with AI-powered call recordings. So I'm going to select one of my meetings that's already been recorded.

Now on the left, you'll see the video. You can always just watch that like any old video recording. Beneath that, you'll see all the times that people were talking as well as when there's screen share, if it helps you identify specific moments. But to the right, you'll see AI has already started to generate value. Under the summary section, you're gonna see multiple recaps of what happened in that meeting. In this case, you'll see I've got a recap of the outcome, the next steps, and who said them, objections, pain points, and every question that was asked in the meeting. You can just click on the time. It'll take you directly to that moment in the meeting.

Now at the top of the screen is something even cooler, brand new. It's called Ask Apollo. When you click that, this will pop out where you can ask Apollo any questions you want about what happened in that meeting. It'll generate a reply. And if you like it, you can just hit right here to copy it, post it in the comments, or your notes on the record, wherever you keep your information.

The next tab in insights is ‘transcript’. When you get over here, you'll have a full transcript. Probably don't really care for that too much, but what you will care for is the fact you can search the transcript here, and you can highlight anything in that transcript to easily make clips or share it.

Just find the moment you want to share. You'll see that you can copy the text, comment directly on the record here, you could tag other folks in. But if you click that ‘create a clip’ film reel, it'll take just that segment you highlighted, give it a title, a description, and hit ‘create clip’. You can share that outside of your organization in case you want to send a clip to your prospect, for example.

The next tabs in insights are ‘trackers’ and ‘comments’. With trackers, you'll get a full rundown of any of your keyword trackers that were said during the meeting. You can even click on it, and it'll take you directly to that moment in the transcript. If you want to see it on the video, just click the time. It'll automatically bring you to that point so you can hear the person say it.

Comments is where you can leave comments for yourself or for other people in the organization. There's something you want to note, you can pop it in here, and you can tag other folks in. So I'll tag my boss and post. They'll get a notification about the comment.

Now, of course, you're probably gonna wanna be following up with your prospect. You'll notice at the top right, there's a blue button that says ‘auto draft email’. If you hit that, it's gonna put together a great follow-up email that you can use, or you can edit it further. It'll provide a link to the meeting recording for your prospect, an overview of what was discussed, next steps that were identified, and some pleasantries at the end. Of course, you can add anything you'd like or adjust this, but it's a great starting point. And if you aren't doing follow-up emails, this is gonna be a major upgrade.

Now we've been in the insights tab for this meeting all along. You'll notice there's ‘details’, which will provide a breakdown of who was in the meeting and any deals it's associated with.

You'll see your ‘clips’ over here. If you take a clip, it'll show up here. You can rewatch it, reshare it from here.

You'll also see ‘scoring’. This is an easy way to provide feedback to your team or to request feedback from your boss for a peer. You'll notice that you can select a scorecard if you're providing feedback, or you can request feedback as well. Just hit ‘request score’, choose the evaluator, pick the scorecard you want them to use, and you can define these in settings for conversations, and hit ‘request’. They'll get a notification, ask him to fill out that scorecard and watch the meeting or the specific moments of the meeting that you requested. And then when they finish it, it'll show up right here in ‘responses’.

It's so important to always be getting better and getting feedback. If you're only able to get feedback on one meeting every once in a while, you won't improve fast enough. So if you're on a team, start doing peer-to-peer feedback sessions. Oftentimes, you appreciate the feedback from people doing the same job more than you do anybody else anyways.

The last thing I want to show you is ‘playlists’. You'll see a tab when you go back to the main Conversations menu. And from there, you can put together playlists just like on Spotify or YouTube of the best meetings or meetings that fit into a certain category. Potentially, you wanna create a playlist of the best meetings for that month to highlight people on the team or great examples of certain situations, or objections being handled. Just go to ‘create playlist’, give it a name, say who can watch it (is it only on your team or anybody can?), and hit ‘create’. Once you got your playlist created, you can start choosing which meetings you wanna put in there. Just go to the meeting, hit the three dots next to it, and go ‘add to playlist’.

That's the end of the course. You're now all set up with Conversations, and with AI-powered call recording, you're about to transform the way you sell. So best of luck. Happy selling.`}],m=[{title:"Intro",shortDescription:"",wistiaId:"dkgjz5j5k1",length:"1:12",deepLink:{heading:"Find and close your next deal in Apollo",url:"/sign-up",linkText:"Sign up for free",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"In this introductory lesson, Sunny Sehmar (Director of Apollo Academy) teases what’s in store for you in this course."}),(0,a.jsx)(s.A,{children:"Get ready to learn how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Use Deals as a lightweight CRM","Set up deal stages like a pro","Integrate your deals seamlessly with HubSpot or Salesforce","Tie all your activities in Apollo into one unified view","And so much more!"]})]}),transcript:`Hi, everyone. This is Sunny from Apollo. In this course, we're gonna cover how to effectively track your deals in Apollo. Whether you're new to the platform or a seasoned pro, I'm gonna show you the best way to stay on top of your sales pipeline. Let's get started.

If you find that you or your team's deals are falling through the cracks and you're constantly switching from spreadsheets, emails, and other tools making it difficult to keep up, then this course is for you. I'm gonna show you how to use Deal management as a lightweight CRM that aggregates insight from all across Apollo into one clear unified view. In this course, I'm gonna cover the basics of setting up your deal stages and how you can integrate your deals with a CRM like HubSpot or Salesforce.

I'll show you how easy it is to create, manage, and update your deals and how to associate other activities you're doing in Apollo, such as your conversations and tasks to create a unified view.

At last, I will show you how to create workflows to automate your processes, saving you a ton of time. Let's get into it.
    `},{title:"Setting up Deals",shortDescription:"",wistiaId:"c5sf0l4weo",length:"4:08",deepLink:{heading:"Like what you’re learning?",url:"https://app.apollo.io/#/deals",linkText:"Use Deals in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"Join Sunny as he walks you through the initial setup of Deals — from creating your pipeline to dialing in your currency."}),(0,a.jsx)(s.A,{children:"By the end of this video, you’ll be ready to start managing deals with ease."}),(0,a.jsx)(s.A,{children:"You’ll learn how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Create a pipeline with stages that fit your business","Define key deal roles ","Customize deal fields to track what matters most to your business","Set up currency preferences for accurate revenue reporting"]})]}),transcript:`In this video, we're gonna walk through the initial setup of Deals.

The first thing we'll do is create a pipeline with deal stages that work for your business. Next, we're gonna define deal roles. A deal role is assigned to a contact that is associated to a deal that you are working. So a few of examples of a deal role are decision maker or executive sponsor. Then we'll create custom fields to track deal data that is specific to your business. The last setting is currency, which is where we will define where your company does business in. Let's jump right in.

So the first place you're gonna wanna start out is in settings. Open the section for object and find Deals. Within Deals, you'll see an option to create a pipeline. Click on the ‘create pipeline’ button at the top right. For this deal, I'll call this Apollo pipeline. This will be a name that's specific to your business.

Now that we've created our pipeline, it's time to select some deal stages to associate to it. The deal stages you choose here will be specific to your business. So you can see that there are some default stages here to keep, or you can create your own stage. So let's go ahead and create one. 

I see that I am missing a stage for a solution presentation, so let's go ahead and add that here. I'm gonna go ahead and click on ‘create stage’. I'm gonna type in ‘solution presentation’. This is an open pipeline type, so I'm gonna keep that to open. We're gonna change the probability. Once you get to this stage, probability is at fifty percent, so I'm gonna update that there. And we're gonna go ahead and click ‘add’. 

Great. We've got ‘solution presentation’ listed here. Now I'm gonna change the arrangement of this. You can click on these two little bar arrows and move this up. Typically, solution presentation comes right before negotiation, so I'm gonna slot that in right there. Alright.

Awesome. We have our deal stages. Go ahead and click ‘go back’. And next up, we're gonna add deal roles. 

So click on ‘deal roles’ in the top left. You're gonna see some predefined options here. The deal roles are roles specific to the contacts that are associated to your deal. So if you're working with Sarah from company x and she's the decision maker, we wanna be able to associate her as a decision maker in Apollo. So we have that available to us. If you wanna add a new role, you can do so here as well. 

Now on to fields. Alright. Again, we have some really great built-in fields here that are gonna allow you to track your deals really well. But we also have the ability to add some custom fields. So let's go ahead and click on ‘create field’ on the top right-hand corner. And I'm gonna select a single select pick list field type for this example. And what I wanna track is the deal type.

I see we don't have an existing field for this, and I want to create some custom pick list options. So I'm gonna pick new deal as one option and add another one as existing deal. Okay. Great. That's gonna allow me to distinguish what type of deal this is. Click ‘save’. Scroll down below to your custom fields, and you'll see your new custom field listed down below here as deal type.

One last area to show you under settings is currency.

So the currency is the currency that you're gonna be using for reporting revenue. So this is your company currency.And for this instance, I'm in the US, so I have US selected. You also have a few different options that work for you down below here depending on what currency your company operates in. If your currency is not listed here, you can add a currency down below here and select from a whole list of currencies that work for you. Once you've added your currency, it's as easy as just toggling it on and off.
`},{title:"Creating & managing deals",shortDescription:"",wistiaId:"ktyhb7p6qe",length:"5:01",deepLink:{heading:"Like what you’re learning?",url:"https://app.apollo.io/#/deals",linkText:"Use Deals in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"Now that your settings are in order, it’s time to learn the ins and outs of actually creating and managing deals."}),(0,a.jsx)(s.A,{children:"You’ll learn how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Create your very first deal","Log activities, add notes, and set tasks","Update deal fields quickly and customize your view","And more!"]})]}),transcript:`In this video, we're gonna cover how you can easily create, manage, and update your deals in Apollo. Let's get into it.

We're gonna start out in the Deal section of Apollo. If you go to your left side nav and click on deals, you'll land on the deals home screen.

The first thing we're gonna do is create our first deal. So we're gonna click on the create deal button in the top right-hand corner. That's gonna pop up in the sidebar. And the first thing we're gonna do is create a deal name. I like to use a naming convention, so I like to put in the license count, the amount for that deal, as well as the company that I'm selling into.

Down below, you're gonna choose your pipeline. So if you've created your own pipeline like you have from the last video, you wanna select that here. For me, I'm gonna select Apollo pipeline. 

Next up, you're gonna click on ‘stage’. And these will be the stages that you've assigned to your pipeline. If you are integrated with HubSpot or Salesforce and you've synced by directionally, all of your stages from your CRM, you'll see the stages from your CRM listed here.

For this example, I'm gonna pick ‘solution presentation’ as the stage that I'm in. I'm gonna pick the company. And now I'm gonna pick an estimated close date. So I'll pick a date in the future here. I'm gonna choose an owner, and then I'm gonna enter the amount. I'm set up with US dollars as my currency, so I'm gonna keep that as the default. And I've also associated some custom fields to this pipeline. So I am going to populate the type of field, the lead source, as well as the deal type, and click ‘save’. 

Alright. Congratulations. Your first deal has been created. This is your deal screen. So this is all information related to your deal. All of this is customizable. You'll see the default deal information on the left hand side. You'll see deal information that you can update in line. I'm gonna go ahead and do that for next step. Schedule demo. Hit ‘save’. And see that saved immediately. 

Down below your deal field, you'll see activity. So you can log a call, add a conversation, and all that will get tracked here. For every deal you create, it's also best practice to add a contact. So let's go ahead and do that. 

Let's click on the plus sign to add a contact. You can start typing in a contact name. You'll wanna select a role for that contact. So in this situation, John will be the decision maker. We'll set him as the primary contact. We're gonna hit ‘save’. And now we've associated John here. And the benefit of having John associated as a contact is if we ever log a call against John or we have a conversation that's recorded and captured within Apollo, all of that will be associated into the activity feed here.

So two last things we can do with the deal is add a note and a task. So let's go ahead and add a note. This could be anything you really want to add that's related to this deal. I'll say I spoke with John today, and he's excited to move forward. I'm gonna associate that to John. I'm a guy associated with this deal. We're gonna save that note. 

Now last, we're gonna add a task. Click ‘add task’. Enter a task title. I'm gonna enter a reminder, schedule a demo call, assign it to myself, pick a due date, and create the task. 

Now that I have my deal logged in, at a glance, I'll be able to see all my past history of this deal as well as the next activity I need to do. This is gonna make my life easier as I work several leads throughout my week. 

Now that I have created my deal, I can see it listed in my deal pipeline. Not only do I see the deal I created, I can also update fields on the fly directly from this view by simply double clicking the field I want to update.

Let's say the deal amount for my new deal has now gone up from two thousand dollars to three thousand dollars. I can quickly make that change right here. I also have the ability to rearrange these fields as I like. I can simply click on a field and drag it to the ideal position that I wanna put it in.

If I wanna add or remove a field from this view, I can do that by clicking on view options, going down to fields, and selecting any fields that I want here. 

Last, I can switch my entire layout from table to kanban. If I click on kanban, I now have this card design here. I can see all my deals in different stages. Let's say I've successfully now closed my deal for five seats of Acme. I can click and drag my deal all the way to close one. 
`},{title:"Using workflow automation",shortDescription:"",wistiaId:"1tyrg4qyw3",length:"5:25",deepLink:{heading:"Like what you’re learning?",url:"https://app.apollo.io/#/deals",linkText:"Use Deals in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"In this lesson, you'll learn how to put your deal creation and follow-ups on autopilot with workflow automation."}),(0,a.jsx)(s.A,{children:"Join Sunny as he teaches you how to take the busywork out of deal management."}),(0,a.jsx)(s.A,{children:"You’ll learn how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Auto-create deals the moment a contact shows interest","Build out smart workflows that automatically set the right stages & contacts","Set up follow-up tasks for deals that have gone quiet","Stay in the loop with task reminders","And more!"]})]}),transcript:`In this video, I'm gonna show you how to use workflow automation to save you a ton of time when using Deals in Apollo.

We are gonna create two automated workflows.

One that automatically creates deals when a contact is interested, and another to help you follow-up on deals that aren't progressing.

We're starting out on the Workflow home screen. Click create workflow, and you will see two options.

The first is to create from scratch, and the second is to start with a template. Today, we're gonna start with a template.

Here, you'll see a bunch of templates you can use to help you save time. Today, we're gonna focus on ‘win more deals’. So I'm gonna click on win more deal templates. And the two we're gonna create are ‘create a deal when a contact is interested’ ‘and follow-up on deals showing no progress’.

Let's click on the first one, ‘create deals when a contact is interested’. Okay. This explains what's gonna happen when this workflow triggers. So when a contact stage is marked as interested, we'll automatically create a deal. We'll also link that contact to that deal. 

Let's go ahead and click ‘create’. Now we are in the workflow builder ready to customize our template. And what we wanna do is follow this simple logic. If you've never customized a workflow before, don't worry. We will go through it together, and it will become even easier for you in the next one. 

Okay. So this logic is as follows. When this happens, then do this. What we're gonna do is click on this ‘contact updated’ section, and this is saying run this workflow based on a trigger event. So that trigger event is when a contact is updated and the contact stage and we're gonna select the stage here and say ‘interested’.

So, again, when this contact is updated and the stage is set to interested, something is gonna happen. Right? So we're gonna save this trigger, and now we're gonna define what's gonna happen.

So then do this. So it's gonna create a deal, and we can customize this even further as well. So what this says is it's gonna create a deal, and we're gonna select the pipeline that we wanted to add to. And we can also select the deal stage.

So we'll automatically set that deal stage to ‘sales qualified’. We'll also select contact role and the deal owner. You also have the option of preventing duplicates. So you can keep that unchecked, and we'll click on ‘save action’.

Okay. So when the contact is updated, we're gonna create the deal and set the deal stage to sales qualified. What we also wanna do is link the contact to the deal. So this says link the contact to deals exclusively when the deal stage is in stage sales qualified. And we'll select that contact role as well and click ‘save to action’. 

Once everything is dialed in as we've done, go ahead and click ‘save’ in the right hand corner. 

Okay. All that's left now is to toggle our workflow on. That's activated the workflow. We're gonna click on ‘save’ and activate in the top right hand corner now. Okay. We're all set.

Now let's go to our next workflow.

Go ahead and click ‘create workflow’ once again and click ‘start with a template’. Navigate down to ‘win more deals’. Click on ‘follow-up deals showing no progress’. So this is going to give us a task reminder to follow-up if a deal has not been updated within fourteen days. So we're gonna click on that. 

Here's what's gonna happen. It's gonna create that deal task and, optionally, send a reminder via Slack, email, or by other means. So let's click on ‘create’, and let's start customizing our workflow. 

So we're first gonna customize when we want the follow-up to happen. So I'm gonna click on the first step. You can choose to start this immediately after we activate or a time in the future. I'm gonna pick a time in the future, and I'm gonna have this run every day. And down below, you can see the attributes that make up this criteria. So if I click on ‘add filter’, it's gonna show that when I'm the owner and when the stage has been fourteen days since it's been updated, that's what's gonna trigger this. We're gonna save this and click ‘save trigger’. 

Now we'll customize the action we wanna happen as part of this workflow. Click on the action item. So this is gonna create a deal task. It's gonna assign me as the owner. It's gonna set the priority to medium, and it's gonna set the due date to one day.

And I'm gonna add a note in here to say ‘follow-up on this deal’ because there's been no action in fourteen days, and I'm gonna save that action.

Okay. We've completed this workflow now for follow-up on deals showing no progress. We're gonna hit ‘save’ in the top right-hand corner. It's gonna save our work.

We're gonna activate the flow again by toggling it on. Click ‘save and activate’. And we're all done. 

Now that you know how to use Apollo Deals to stay on top of your pipeline and win business, be sure to check out our other courses on our Academy page to help you get the most out of your Apollo account.
`}],p=[{title:"Settings for success",shortDescription:"Learn how to set up your Apollo account for success before you build your lead list.",wistiaId:"fkom2ofwrt",length:"7:37",deepLink:{heading:"Like what you're learning?",url:"https://app.apollo.io/#/login",linkText:"Do it in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"First things first—your settings. Before you dive into finding leads in Apollo, it's important to set up your account for success."}),(0,a.jsx)(s.A,{children:"This lesson is all about laying the tracks before the train. Join host Josh Garrison as he reveals some of the most impactful settings for getting the most out of your Apollo account, such as:"}),(0,a.jsxs)(n.A,{children:[(0,a.jsx)(s.A,{children:"Email settings:"}),(0,a.jsx)(i.A,{color:"purple",items:["How to link your mailbox","How to improve your email deliverability","Why you should let recipients opt out of your emails","What number to set your sending limit to","How to add a text-based signature (and why you shouldn’t use an image-based one)"]})]}),(0,a.jsxs)(n.A,{children:[(0,a.jsx)(s.A,{children:"Voice settings:"}),(0,a.jsx)(i.A,{color:"purple",items:["How to configure your phone number to make calls from Apollo","How to create a bridge to your cell phone from Apollo"]})]}),(0,a.jsx)(s.A,{children:"And more..."})]})},{title:"Building a targeted lead list",shortDescription:"Find your ideal leads using Apollo’s 65+ filters to narrow down your search, and create Personas to save time.",wistiaId:"llcafiafs8",length:"5:08",deepLink:{heading:"Like what you're learning?",url:"https://app.apollo.io/#/login",linkText:"Do it in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsxs)(s.A,{variant:"h5",children:["Now that you've set your account up for success, it's time to do some prospecting in Apollo's database of over"," ",l.CN," million people and build your first lead list."]}),(0,a.jsxs)(s.A,{children:["But how do you go from ",l.CN," million people to less than a few hundred highly-relevant leads?"]}),(0,a.jsx)(s.A,{children:"In this lesson, you'll learn:"}),(0,a.jsx)(i.A,{color:"purple",items:["How to use Apollo’s 65+ filters to narrow down your list based on job title, industry, software used, location, and more","Why a lead list of dozens is often better than a list of hundreds","How to build a persona to save time on future prospecting searches","How to filter your list even further by targeting only those with a verified email address","And more!"]})]})},{title:"Building a targeted lead list, pt. 2",shortDescription:"Save your leads to lists, find mobile phone numbers, and add leads to a sequence.",wistiaId:"g12ias1efe",length:"3:26",deepLink:{heading:"Like what you're learning?",url:"https://app.apollo.io/#/login",linkText:"Do it in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"You've built a targeted lead list, now Josh will teach a few tips & tricks to maximize your prospecting efforts."}),(0,a.jsx)(s.A,{children:"In this lesson, you'll learn how to really set the stage for successful outreach, including how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Save mobile numbers in bulk","Add your prospects to a custom list","Apply a phone status filter so you can separate people who have a mobile number from those who don’t (and eventually build sequences for both)","And more!"]})]})},{title:"The Google Chrome Extension",shortDescription:"Use Apollo’s Chrome Extension to access verified contact data and engage instantly on the tools you use every day, including LinkedIn, Gmail, Google Calendar, Salesforce, and any company website.",wistiaId:"vwpzed4f7s",length:"3:35",deepLink:{heading:"Ready to give Apollo’s Chrome extension a go?",linkText:"Download it free",url:"https://chromewebstore.google.com/detail/apolloio-free-b2b-phone-n/alhgpfoeiimagjlnfekdhkjlkiomcapa"},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"In this lesson, you'll discover one of Apollo's greatest secret weapons: the Chrome extension."}),(0,a.jsx)(s.A,{children:"The Chrome extension lets you take the power of Apollo wherever you're prospecting online—LinkedIn, Gmail, Google Calendar, Salesforce, a company's website—you name it."}),(0,a.jsx)(s.A,{children:"Join Josh as he demonstrates:"}),(0,a.jsx)(i.A,{color:"purple",items:["How to install the extension","How to use the LinkedIn integration to get valuable contact and company insights on the spot","The magic of “Apollo Everywhere”—a feature that extends your prospecting capabilities to any website, offering instant access to company information, technologies, hiring status, and more","How to add someone to a sequence straight from the extension","And more!"]})]})},{title:"Building a Sequence",shortDescription:"Take the lead list you’ve built and add them to a sequence. Build sequences with automatic or manual emails, phone calls, and LinkedIn touches.",wistiaId:"dpjs6lx4c8",length:"9:54",deepLink:{heading:"Like what you're learning?",url:"https://app.apollo.io/#/login",linkText:"Do it in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"You've built a lead list, now it's time for the good stuff: adding your leads to a sequence so you can start reaching out."}),(0,a.jsx)(s.A,{children:"Calls, emails, LinkedIn touches—this is the bread and butter of outreach, and there's no better place to do it than Apollo. Join Josh as he shows you why."}),(0,a.jsx)(s.A,{children:"In this lesson, you'll learn how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Use pre-built templates or build sequences from scratch","Add steps to your sequences","Create manual emails for optimal personalization","Utilize dynamic variables, such as first names, to personalize your emails automatically","Use if/then statements for more sophisticated personalization","Set up A/B tests to refine your email strategy","And more!"]})]})},{title:"Mastering your workflow",shortDescription:"See how Apollo works when you put it all together: find someone from the database, add them to a sequence, work through the call and email tasks, and more.",wistiaId:"f2qg8nsz6j",length:"5:49",deepLink:{heading:"Like what you're learning?",url:"https://app.apollo.io/#/login",linkText:"Do it in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"This lesson is about taking everything you've learned in lessons 1-4 and putting it all together."}),(0,a.jsx)(s.A,{children:"Join Josh as he finds someone in Apollo's database, adds them to a sequence, then effortlessly works through the call and email tasks."}),(0,a.jsx)(s.A,{children:"You'll also learn how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Activate your sequences","Complete sequence tasks from your Home screen","Make calls from Apollo (with bonus tips for how to leave voicemails)","And more!"]})]})},{title:"Mastering your workflow, pt. 2",shortDescription:"Learn how to use Apollo’s Chrome extension to send a LinkedIn connection request, and how to duplicate a sequence for people without phone numbers.",wistiaId:"8y60d1ahm3",length:"6:12",deepLink:{heading:"Like what you're learning?",url:"https://app.apollo.io/#/login",linkText:"Do it in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"The workflow wizardry continues as Josh showcases a few other tips for optimizing your day-to-day, such as:"}),(0,a.jsx)(i.A,{color:"purple",items:["How to rearrange sequence steps","Tips for connecting on LinkedIn","How to duplicate sequences to cater to contacts with and without mobile numbers"]}),(0,a.jsx)(s.A,{children:"With that, you've learned all the essential skills you need to find targeted leads and book meetings in Apollo. But even so, this course has barely scratched the surface of what Apollo (and you) can do."}),(0,a.jsxs)(s.A,{component:"span",children:["If you're hungry to learn more, check out our"," ",(0,a.jsx)(h,{href:"https://knowledge.apollo.io/hc/en-us",children:"Knowledge Base"}),", head back to ",(0,a.jsx)(h,{href:"/academy",children:"Apollo Academy"}),", or simply"," ",(0,a.jsx)(h,{href:"https://app.apollo.io/#/login",children:"log in to Apollo"})," ","and poke around."]})]})}],y=[{title:"Settings for success",shortDescription:"Set your Apollo account up for success so your team can hit the ground running.",wistiaId:"k1t8obvn9c",length:"6:32",description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"Join host Josh Garrison as he demystifies Apollo's settings and walks through how to set up a powerhouse framework for your sales team."}),(0,a.jsx)(s.A,{children:"This lesson is all about empowering your team to hit the ground running as soon as they log in. You'll learn how to:"}),(0,a.jsx)(i.A,{color:"purple",items:["Create territories so reps stay in their own lane","Manage Apollo access & permission profiles","Set restrictions to avoid “account stealing”","Ensure you can send emails on behalf of reps","Manage access to call recordings","And more!"]})]}),deepLink:{heading:"Like what you're learning?",url:"https://app.apollo.io/#/login",linkText:"Do it in Apollo",extraPadding:!0}},{title:"Settings for success, pt. 2",shortDescription:"Continue setting up your Apollo account by learning how to deactivate seats, manage your plan, and create teams.",wistiaId:"1olya19ve0",length:"3:46",deepLink:{heading:"Like what you're learning?",url:"https://app.apollo.io/#/login",linkText:"Do it in Apollo",extraPadding:!0},description:(0,a.jsxs)(n.A,{spacing:3,children:[(0,a.jsx)(s.A,{variant:"h5",children:"The sojourn through Apollo's settings continues as Josh does a deep dive on how you can:"}),(0,a.jsx)(i.A,{color:"purple",items:["Deactivate users","View plan settings & credit usage","Create credit limits for each user","Group